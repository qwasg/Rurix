entry:
  %rx_h_src = call target("dx.Texture", float, 0, 0, 0, 2) @llvm.dx.resource.handlefrombinding(i32 0, i32 0, i32 1, i32 0, ptr null)
  %rx_h_dst = call target("dx.Texture", float, 1, 0, 0, 2) @llvm.dx.resource.handlefrombinding(i32 0, i32 0, i32 1, i32 0, ptr null)
  %v0 = call float @llvm.dx.resource.load.level(target("dx.Texture", float, 0, 0, 0, 2) %rx_h_src, <2 x i32> zeroinitializer, i32 0, <2 x i32> zeroinitializer)
  call void @llvm.dx.resource.store.texture(target("dx.Texture", float, 1, 0, 0, 2) %rx_h_dst, <2 x i32> zeroinitializer, float %v0)
