//@ spec: RXS-0171, RXS-0158, RXS-0161, RXS-0162, RXS-0172
// UC-04 deferred lighting/合成 pass vertex(选项 B:不采样 G-buffer 的最小多 pass deferred)。
// 与几何 pass 同顶点缓冲布局(pos/uv/normal),透传 pos→SV_Position + uv→插值 varying
// 供 lighting fragment 走**自身插值输入**(不读 G-buffer = 选项 B 折中边界,采样完备性
// 仍 blocked 于 RD-021 / 06§4.2 禁区)。body 仅 Use + 单层 Field 投影 + 输出聚合分解
// → 逐 Out OpStore(RXS-0171 L4 白名单);pos→#[builtin(position)] vec4 = SV_Position。
struct VsIn {
    pos: vec4<f32>,
    uv: f32,
    normal: f32,
}

struct LpVary {
    #[builtin(position)] clip: vec4<f32>,
    #[interpolate(perspective)] uv: f32,
}

vertex fn uc04_lighting_vs(inp: VsIn) -> LpVary {
    LpVary { clip: inp.pos, uv: inp.uv }
}
