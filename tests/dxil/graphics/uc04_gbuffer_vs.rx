//@ spec: RXS-0171, RXS-0158, RXS-0161, RXS-0162, RXS-0172
// UC-04 deferred 几何 pass vertex(RXS-0171 body I/O 数据流降级:顶点缓冲属性透传):
// 读顶点输入属性(pos:裁剪空间位置 vec4 / uv / normal)→ 透传到输出(SV_Position +
// 插值 varying uv/normal 供下游 fragment 几何 pass 写 G-buffer MRT)。body 仅 Use +
// 单层 Field 投影 + 输出 I/O 聚合返回值机械分解 → 逐 Out OpStore(RXS-0171 L4 白名单)。
// **几何 pass 不采样 G-buffer**(采样归 lighting pass = RD-021 / 06§4.2 禁区,见
// evidence/g2.4-uc04-deferred/rd021_scoping_20260629.md);本语料只透传 + 写,在白名单内。
// pos→#[builtin(position)] vec4<f32> = SV_Position(裁剪空间,RXS-0159 系统值映射,
// device 可光栅化);uv/normal→插值 varying;顶点输入名经 RXS-0159 IR1(a) 保名。
struct VsIn {
    pos: vec4<f32>,
    uv: f32,
    normal: f32,
}

struct GBufVary {
    #[builtin(position)] clip: vec4<f32>,
    #[interpolate(perspective)] uv: f32,
    #[interpolate(perspective)] normal: f32,
}

vertex fn uc04_gbuffer_vs(inp: VsIn) -> GBufVary {
    GBufVary { clip: inp.pos, uv: inp.uv, normal: inp.normal }
}
