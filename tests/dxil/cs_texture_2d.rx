//@ spec: RXS-0157
// GRX-009 段 stage 3:2D texel 方法调用 DXIL golden 语料。`Texture2D<f32>.load(x, y)`
// (SRV texel 读)与 `RWTexture2D<f32>.store(x, y, v)`(UAV texel 写)以真实 2D
// `(x, y)` texel 坐标(区别于 1D `tex[idx]` 的 `(idx, 0)`)。golden 形态:
// 1) rurixc 自有 DirectX 三元组 LLVM IR 文本(`.dxil-ll`),coords 经 `insertelement`
//    组装 `<2 x i32> (x, y)`,`@llvm.dx.resource.load.level` / `@llvm.dx.resource.store.texture`;
// 2) 经 patched llc → DXIL 容器 + dxc validator 接受后的文本反汇编(`.dxil-disasm`,
//    `dx.op.textureLoad(66)` / `dx.op.textureStore(67)` 的 coord0/coord1 取 x/y)。
kernel fn cs_texture_2d(src: Texture2D<f32>, dst: RWTexture2D<f32>, t: ThreadCtx<1>) {
    let x = t.global_id();
    let y = t.global_id();
    let v = src.load(x, y);
    dst.store(x, y, v);
}
