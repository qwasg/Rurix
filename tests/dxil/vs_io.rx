//@ spec: RXS-0159
// vertex 着色阶段 I/O DXIL golden 语料(RXS-0159 阶段 I/O → DXIL 签名/系统值语义,
// 类型面)。输入 vertex_id → SV_VertexID;输出 position → SV_Position + 透视插值
// varying uv → interp:linear。golden:`.dxil-ll`(rurixc 自有 DirectX 三元组 LLVM IR
// + 类型面签名元数据 !rurix.dxil.sig.in/out,确定性、无外部工具);`.dxil-disasm`
// (经 patched llc + dxc validator 接受后反汇编)在带工具链环境录入,本仓库 dev 环境
// 工具链缺失 → disasm 关卡 SKIP(RD-011)。入口 body 数据流降级 deferred(RD-013)。
struct VsIn { #[builtin(vertex_id)] vid: u32 }
struct VsOut { #[builtin(position)] pos: f32, #[interpolate(perspective)] uv: f32 }
vertex fn vs_io(inp: VsIn) -> VsOut { VsOut { pos: 0.0, uv: 0.0 } }
