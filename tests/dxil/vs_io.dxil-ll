; ModuleID = 'vs_io'
source_filename = "vs_io"
target datalayout = "e-m:e-p:32:32-i1:32-i8:8-i16:16-i32:32-i64:64-f16:16-f32:32-f64:64-n8:16:32:64"
target triple = "dxil-unknown-shadermodel6.0-vertex"

define void @rx_vs_io_13() #0 {
entry:
  ret void
}

attributes #0 = { noinline nounwind "hlsl.shader"="vertex" }

; RXS-0159 stage I/O signature (type-face: SV semantic names + interpolation modifiers
; only; signature element register / offset / component-mask binary layout is RFC-0003
; §4.6 / §9 Q-Builtin FFI-ABI 禁区, emitted by the LLVM DirectX backend, not by Rurix).
!rurix.dxil.sig.in = !{!0}
!rurix.dxil.sig.out = !{!1, !2}
!0 = !{!"vid", !"SV_VertexID"}
!1 = !{!"pos", !"SV_Position"}
!2 = !{!"uv", !"interp:linear"}
