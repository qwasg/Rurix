; ModuleID = 'saxpy'
source_filename = "saxpy"
target triple = "nvptx64-nvidia-cuda"

declare i32 @llvm.nvvm.read.ptx.sreg.ctaid.x()
declare i32 @llvm.nvvm.read.ptx.sreg.ntid.x()
declare i32 @llvm.nvvm.read.ptx.sreg.tid.x()

define ptx_kernel void @rx_saxpy_8(ptr addrspace(1) %arg1, ptr addrspace(1) %arg2, ptr addrspace(1) %arg3, float %arg4, i64 %arg5) {
entry:
  %l1 = alloca ptr addrspace(1), addrspace(5)
  %l2 = alloca ptr addrspace(1), addrspace(5)
  %l3 = alloca ptr addrspace(1), addrspace(5)
  %l4 = alloca float, addrspace(5)
  %l5 = alloca i64, addrspace(5)
  %l7 = alloca i64, addrspace(5)
  %l8 = alloca i64, addrspace(5)
  %l9 = alloca i8, addrspace(5)
  %l10 = alloca float, addrspace(5)
  %l11 = alloca float, addrspace(5)
  store ptr addrspace(1) %arg1, ptr addrspace(5) %l1
  store ptr addrspace(1) %arg2, ptr addrspace(5) %l2
  store ptr addrspace(1) %arg3, ptr addrspace(5) %l3
  store float %arg4, ptr addrspace(5) %l4
  store i64 %arg5, ptr addrspace(5) %l5
  br label %bb0
bb0:
  %t0 = call i32 @llvm.nvvm.read.ptx.sreg.ctaid.x()
  %t1 = call i32 @llvm.nvvm.read.ptx.sreg.ntid.x()
  %t2 = call i32 @llvm.nvvm.read.ptx.sreg.tid.x()
  %t3 = mul i32 %t0, %t1
  %t4 = add i32 %t3, %t2
  %t5 = zext i32 %t4 to i64
  store i64 %t5, ptr addrspace(5) %l8
  br label %bb1
bb1:
  %t6 = load i64, ptr addrspace(5) %l8
  store i64 %t6, ptr addrspace(5) %l7
  %t7 = load i64, ptr addrspace(5) %l7
  %t8 = load i64, ptr addrspace(5) %l5
  %t9 = icmp ult i64 %t7, %t8
  %t10 = zext i1 %t9 to i8
  store i8 %t10, ptr addrspace(5) %l9
  %t11 = load i8, ptr addrspace(5) %l9
  %t12 = icmp ne i8 %t11, 0
  br i1 %t12, label %bb2, label %bb3
bb2:
  %t13 = load float, ptr addrspace(5) %l4
  %t14 = load ptr addrspace(1), ptr addrspace(5) %l2
  %t15 = load i64, ptr addrspace(5) %l7
  %t16 = getelementptr float, ptr addrspace(1) %t14, i64 %t15
  %t17 = load float, ptr addrspace(1) %t16
  %t18 = fmul float %t13, %t17
  store float %t18, ptr addrspace(5) %l10
  %t19 = load float, ptr addrspace(5) %l10
  %t20 = load ptr addrspace(1), ptr addrspace(5) %l3
  %t21 = load i64, ptr addrspace(5) %l7
  %t22 = getelementptr float, ptr addrspace(1) %t20, i64 %t21
  %t23 = load float, ptr addrspace(1) %t22
  %t24 = fadd float %t19, %t23
  store float %t24, ptr addrspace(5) %l11
  %t25 = load float, ptr addrspace(5) %l11
  %t26 = load ptr addrspace(1), ptr addrspace(5) %l1
  %t27 = load i64, ptr addrspace(5) %l7
  %t28 = getelementptr float, ptr addrspace(1) %t26, i64 %t27
  store float %t25, ptr addrspace(1) %t28
  br label %bb4
bb3:
  br label %bb4
bb4:
  ret void
}

