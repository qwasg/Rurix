; ModuleID = 'device_addrspace_constant'
source_filename = "device_addrspace_constant"
target triple = "nvptx64-nvidia-cuda"

declare i32 @llvm.nvvm.read.ptx.sreg.ctaid.x()
declare i32 @llvm.nvvm.read.ptx.sreg.ntid.x()
declare i32 @llvm.nvvm.read.ptx.sreg.tid.x()

define ptx_kernel void @rx_gather_8(ptr addrspace(4) %arg2, ptr addrspace(1) %arg3, i64 %arg4) {
entry:
  %l2 = alloca ptr addrspace(4), addrspace(5)
  %l3 = alloca ptr addrspace(1), addrspace(5)
  %l4 = alloca i64, addrspace(5)
  %l5 = alloca i64, addrspace(5)
  %l6 = alloca i64, addrspace(5)
  %l7 = alloca i8, addrspace(5)
  store ptr addrspace(4) %arg2, ptr addrspace(5) %l2
  store ptr addrspace(1) %arg3, ptr addrspace(5) %l3
  store i64 %arg4, ptr addrspace(5) %l4
  br label %bb0
bb0:
  %t0 = call i32 @llvm.nvvm.read.ptx.sreg.ctaid.x()
  %t1 = call i32 @llvm.nvvm.read.ptx.sreg.ntid.x()
  %t2 = call i32 @llvm.nvvm.read.ptx.sreg.tid.x()
  %t3 = mul i32 %t0, %t1
  %t4 = add i32 %t3, %t2
  %t5 = zext i32 %t4 to i64
  store i64 %t5, ptr addrspace(5) %l6
  br label %bb1
bb1:
  %t6 = load i64, ptr addrspace(5) %l6
  store i64 %t6, ptr addrspace(5) %l5
  %t7 = load i64, ptr addrspace(5) %l5
  %t8 = load i64, ptr addrspace(5) %l4
  %t9 = icmp ult i64 %t7, %t8
  %t10 = zext i1 %t9 to i8
  store i8 %t10, ptr addrspace(5) %l7
  %t11 = load i8, ptr addrspace(5) %l7
  %t12 = icmp ne i8 %t11, 0
  br i1 %t12, label %bb2, label %bb3
bb2:
  %t13 = load ptr addrspace(4), ptr addrspace(5) %l2
  %t14 = load i64, ptr addrspace(5) %l5
  %t15 = getelementptr float, ptr addrspace(4) %t13, i64 %t14
  %t16 = load float, ptr addrspace(4) %t15
  %t17 = load ptr addrspace(1), ptr addrspace(5) %l3
  %t18 = load i64, ptr addrspace(5) %l5
  %t19 = getelementptr float, ptr addrspace(1) %t17, i64 %t18
  store float %t16, ptr addrspace(1) %t19
  br label %bb4
bb3:
  br label %bb4
bb4:
  ret void
}

