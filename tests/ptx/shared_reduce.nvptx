  call void @llvm.nvvm.barrier0()
  br label %bb2
bb2:
  %t9 = load i64, ptr addrspace(5) %l5
  %t10 = icmp eq i64 %t9, 0
  %t11 = zext i1 %t10 to i8
  store i8 %t11, ptr addrspace(5) %l8
  %t12 = load i8, ptr addrspace(5) %l8
  %t13 = icmp ne i8 %t12, 0
