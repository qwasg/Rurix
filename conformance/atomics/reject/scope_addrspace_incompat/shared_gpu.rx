//@ spec: RXS-0080
//@ expect-error: RX3010
// rank 格相邻边界(Block < Gpu):`AtomicView<shared, ..>`(addrspace 3)为 block
// 本地存储,使用宽于 `Scope::Block` 的 `Scope::Gpu` → 与地址空间不相容 / 越权,
// 保守拒绝(RX3010,RXS-0080)。

kernel fn shared_gpu_scope(t: ThreadCtx<1>, counters: AtomicView<shared, u32, (16,)>) {
    let i = t.thread_index();
    counters.fetch_add(i, 1, Scope::Gpu);
}

fn main() {}
