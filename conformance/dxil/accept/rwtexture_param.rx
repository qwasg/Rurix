//@ spec: RXS-0157
// GRX-009:Texture2D<f32>(SRV)+ RWTexture2D<f32>(UAV)compute 入口形参进入
// 离线绑定布局推导,body lowering 走 `@llvm.dx.resource.load.texture.2d` /
// `@llvm.dx.resource.store.texture.2d`(替代 raw-buffer 路径,strict-only f32)。
kernel fn k(src: Texture2D<f32>, dst: RWTexture2D<f32>) {
    dst[0] = src[0];
}
