//@ spec: RXS-0023, RXS-0029
// Literal and range patterns in match arms.

fn classify(n: i32, c: char, f: bool) -> u32 {
    match n {
        0 => 0,
        1..=9 => 1,
        10..20 => 2,
        -9..=-1 => 3,
        _ => 4,
    };
    match c {
        'a' => 0,
        'b'..='z' => 1,
        _ => 2,
    };
    match f {
        true => 1,
        false => 0,
    }
}
