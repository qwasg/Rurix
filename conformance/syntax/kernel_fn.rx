//@ spec: RXS-0005
// kernel fn with typed execution shape (05 s1/s6, D-102/D-120).

kernel fn saxpy(
    grid: Grid<(1024,)>,
    a: f32,
    x: View<global, f32, (N,)>,
    y: ViewMut<global, f32, (N,)>,
) {
    let i = grid.thread_index();
    y[i] = a * x[i] + y[i];
}

kernel fn fill<const N: usize>(
    grid: Grid<(N,)>,
    value: f32,
    out: ViewMut<global, f32, (N,)>,
) {
    out[grid.thread_index()] = value;
}
