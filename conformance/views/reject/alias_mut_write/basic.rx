//@ spec: RXS-0078
//@ expect-error: RX3007
// split_at 的低半 lo 与父 view v 区间重叠;对 lo 与 v 同时发起可变写构成别名
// 可变 view 写冲突(证不出不相交,保守拒绝 RX3007,RXS-0078)。

kernel fn alias_parent(v: ViewMut<global, f32>, i: usize, t: ThreadCtx<1>) {
    let (lo, hi) = v.split_at(4);
    lo[i] = 1.0;
    v[i] = 2.0;
}

fn main() {}
