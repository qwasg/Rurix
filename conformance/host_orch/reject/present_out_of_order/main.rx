//@ spec: RXS-0197
//@ expect-error: RX4001
// present typestate 错序(RXS-0197):`signal` 消费 Acquired 后再取
// backbuffer = move 后再用,复用 RXS-0054 既有裁决(RX4001,零新码)。
fn main() -> i32 {
    let ctx = Context::create();
    let sess = Present::create(&ctx, 64, 64, 64, 64);
    let ready = sess.ready();
    let acq = ready.wait();
    let pres = acq.signal();
    let bb = acq.backbuffer();
    let again = pres.present();
    ctx.sync();
    0
}
