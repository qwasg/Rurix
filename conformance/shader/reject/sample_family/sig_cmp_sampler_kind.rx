//@ spec: RXS-0223
//@ expect-error: RX3014
// 签名违例(RFC-0013 §4.B1 签名表):sample_cmp 的 sampler 实参须 SamplerCmp
// 比较采样器;普通 Sampler → RX3014。
struct SfVary {
    #[interpolate(perspective)] uv: vec2<f32>,
}

struct SfOut {
    #[interpolate(perspective)] shadow: f32,
}

fragment fn fs_cmp_kind(inp: SfVary, tex: Texture2D<f32>, samp: Sampler) -> SfOut {
    SfOut { shadow: tex.sample_cmp(samp, inp.uv, 0.5) }
}

fn main() {}
