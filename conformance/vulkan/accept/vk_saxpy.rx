//@ spec: RXS-0203
// mb1 MB1.1 compute lowering(saxpy 规范 UC):多存储缓冲(out/x)+ push constant 标量
// (a/n)+ compute builtin(global_id)+ 算术(fmul/fadd)+ 比较(i<n)+ 结构化 if
// (OpSelectionMerge/OpBranchConditional)。--target vulkan 产 SPIR-V GLCompute,经
// spirv-val --target-env vulkan1.0 严格校验接受。
kernel fn saxpy(out: ViewMut<global, f32>, x: View<global, f32>,
                a: f32, n: usize, t: ThreadCtx<1>) {
    let i = t.global_id();
    if i < n {
        out[i] = a * x[i] + out[i];
    }
}
