From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Rurix Godot Bridge <rurix@example.invalid>
Date: Sat, 12 Jul 2026 11:00:00 +0800
Subject: [PATCH] Add the GRX-013 particles_copy recording-smoke and gated
 real-pass opt-in arms with result writeback scaffold

Stacked on 0001..0021. This is the GRX-013 bridge-recording / real-pass
opt-in slice (the GRX-009 0008+0009+0010 layers merged into one patch for
the particles_copy pass), mirroring GRX-012 0019. It is a bring-up gate, not
a default enablement, and it does not change the shipping fallback semantics.

- modules/rurix_accel/register_types.cpp: adds three per-pass opt-in
  settings that all default to false and are separate from
  rendering/rurix_accel/passes/particles_copy/enabled:
  .../particles_copy/dispatch_recording_smoke,
  .../particles_copy/dispatch_real_pass, and
  .../particles_copy/real_pass_force_capability_downgrade.
- modules/rurix_accel/rurix_accel.h: declares the reserved particles_copy
  real-pass arm flag RXGD_CAP_PARTICLES_COPY_REAL_PASS (bridge value 1 << 7)
  carried in RxGdCaps.flags. This reuses the existing flags field: the C
  ABI struct layout and RXGD_ABI_VERSION are unchanged.
- modules/rurix_accel/rurix_accel.cpp: try_create_session() sets
  RXGD_CAP_PARTICLES_COPY_REAL_PASS ONLY when the particles_copy
  dispatch_real_pass opt-in is enabled, and clears RXGD_CAP_SHADER_INT64 ONLY
  when the harness-only particles_copy real_pass_force_capability_downgrade knob
  is enabled (particles_copy's kernel carries no i64 push-constant fields, so
  int64 is not part of its binding preflight, but the bridge's dispatch
  eligibility requires it for the recording harness). try_record_particles_copy()
  emits RXGD_GODOT_RUNTIME_PARTICLES_COPY_REAL_PASS only on the real-pass arm and
  RXGD_GODOT_RUNTIME_PARTICLES_COPY_RECORD only under the harness-only
  dispatch_recording_smoke opt-in.
- particles_storage.cpp COPY_MODE_FILL_INSTANCES dispatch: when
  try_record_particles_copy() returned true on the real-pass arm, the bridge
  dispatched the fill-instances kernel into the real Transforms SSBO destination
  ID3D12Resource*, so the subset result is physically written into the instance
  buffer. The result writeback SCAFFOLD prints
  RXGD_GODOT_RUNTIME_PARTICLES_COPY_REAL_PASS_WRITEBACK, then clears the flag so
  the FULL native Godot particles copy dispatch still runs as the continuation/
  backstop (the kernel covers only the ALIGN_DISABLED/ALIGN_BILLBOARD 3D subset;
  GPU math parity is still pending measurement).

The bridge fails closed on the real-pass arm and returns RXGD_STATUS_FALLBACK
with a machine-readable RXGD_PARTICLES_COPY_REAL_PASS_BLOCKED diagnostic naming
the FIRST missing prerequisite; the real dispatch is only linked under the
test-only d3d12-recording-shim bridge feature. This does not change
RXGD_ABI_VERSION, does not enable the pass by default (all four particles_copy
per-pass settings still default to false), does not flip real_gpu_pass to
true by itself, and makes no visual, measured-telemetry, GPU-timestamp, or
performance claim by itself.
---
diff --git a/modules/rurix_accel/register_types.cpp b/modules/rurix_accel/register_types.cpp
index 55c4ab5..12a19be 100644
--- a/modules/rurix_accel/register_types.cpp
+++ b/modules/rurix_accel/register_types.cpp
@@ -168,6 +168,38 @@ void initialize_rurix_accel_module(ModuleInitializationLevel p_level) {
 	// RXGD_STATUS_FALLBACK for RXGD_PASS_PARTICLES_COPY, so the native
 	// particles copy keeps rendering in practice and no acceleration is claimed.
 	GLOBAL_DEF_BASIC("rendering/rurix_accel/passes/particles_copy/enabled", false);
+	// GRX-013: harness-only Godot-runtime particles_copy bridge dispatch
+	// recording smoke opt-in (0008-level). Defaults to false so the
+	// shipping build never arms the recording-smoke marker path. It only
+	// gates the module-side RXGD_GODOT_RUNTIME_PARTICLES_COPY_RECORD marker;
+	// the bridge record path itself is only linked when the loaded
+	// rurix_godot.dll is built with the test-only d3d12-recording-shim
+	// feature AND the dispatch_real_pass opt-in below armed the fail-closed
+	// real-pass gate.
+	GLOBAL_DEF_BASIC("rendering/rurix_accel/passes/particles_copy/dispatch_recording_smoke", false);
+	// GRX-013: opt-in gated REAL particles_copy pass bring-up arm (0009-level).
+	// Defaults to false so the shipping build never arms the real-pass
+	// attempt. Even when enabled the bridge runs its runtime binding
+	// preflight, dispatch eligibility, per-slot kernel-binding-kind
+	// conformance (structured_buffer/rwstructured_buffer), and math-parity
+	// checks and keeps returning RXGD_STATUS_FALLBACK (with a machine-readable
+	// RXGD_PARTICLES_COPY_REAL_PASS_BLOCKED diagnostic naming the first missing
+	// prerequisite) unless every check passes AND a runtime-mappable real
+	// dispatch path is linked (d3d12-recording-shim builds only); the
+	// shipping feature-off bridge fails closed with
+	// real_dispatch_path_not_linked, so the native particles copy keeps rendering.
+	GLOBAL_DEF_BASIC("rendering/rurix_accel/passes/particles_copy/dispatch_real_pass", false);
+	// GRX-013: harness-only forced-failure knob for the particles_copy fallback
+	// red/green leg (0009-level template of the luminance
+	// real_pass_force_capability_downgrade). When enabled the module clears the
+	// shader-int64 capability it advertises to the bridge. particles_copy carries
+	// no i64 push-constant fields, so (unlike the texture passes) int64 is not
+	// part of its binding preflight; the bridge's particles_copy dispatch
+	// eligibility still requires the int64 device capability for the recording
+	// harness, so clearing it fails the real-pass arm closed with
+	// unsupported_device while the native Godot particles copy path keeps
+	// rendering. Defaults to false; never enabled by the shipping build/config.
+	GLOBAL_DEF_BASIC("rendering/rurix_accel/passes/particles_copy/real_pass_force_capability_downgrade", false);
 
 #if defined(D3D12_ENABLED)
 	if (GLOBAL_GET("rendering/rurix_accel/enabled")) {
diff --git a/modules/rurix_accel/rurix_accel.cpp b/modules/rurix_accel/rurix_accel.cpp
index c315c07..3720d0d 100644
--- a/modules/rurix_accel/rurix_accel.cpp
+++ b/modules/rurix_accel/rurix_accel.cpp
@@ -268,6 +268,25 @@ void RurixAccelD3D12Hooks::try_create_session() {
 	if (GLOBAL_GET("rendering/rurix_accel/passes/taa_resolve/real_pass_force_capability_downgrade")) {
 		caps.flags &= ~RXGD_CAP_SHADER_INT64;
 	}
+	// GRX-013: arm the opt-in gated REAL particles_copy pass attempt ONLY when
+	// the default-false particles_copy dispatch_real_pass opt-in is enabled. The
+	// bridge still fails closed (fallback + RXGD_PARTICLES_COPY_REAL_PASS_BLOCKED
+	// first missing prerequisite) unless every gate passes AND the
+	// d3d12-recording-shim real dispatch path is linked and completes; this
+	// is a bring-up gate, not a default runtime pass.
+	if (GLOBAL_GET("rendering/rurix_accel/passes/particles_copy/dispatch_real_pass")) {
+		caps.flags |= RXGD_CAP_PARTICLES_COPY_REAL_PASS;
+	}
+	// GRX-013: harness-only particles_copy forced-failure knob. particles_copy
+	// carries no i64 push-constant fields so int64 is not part of its binding
+	// preflight, but the bridge's particles_copy dispatch eligibility still
+	// requires the int64 device capability for the recording harness; clearing it
+	// makes the real-pass arm fail closed with unsupported_device while the native
+	// Godot particles copy path keeps rendering. The fallback red/green leg of the
+	// GRX-013 real-pass enablement smoke verifies exactly this.
+	if (GLOBAL_GET("rendering/rurix_accel/passes/particles_copy/real_pass_force_capability_downgrade")) {
+		caps.flags &= ~RXGD_CAP_SHADER_INT64;
+	}
 	if (adapter_luid_valid) {
 		memcpy(caps.adapter_luid, &adapter_luid, sizeof(adapter_luid));
 	}
@@ -759,6 +778,19 @@ bool RurixAccelD3D12Hooks::try_record_particles_copy(uint64_t p_src_particles_na
 		}
 		return false;
 	}
+	// GRX-013: only reachable when the bridge's opt-in real-pass arm actually
+	// returned RXGD_STATUS_OK after a real recorded dispatch (d3d12-recording-
+	// shim builds only; the shipping feature-off bridge always falls back with
+	// real_dispatch_path_not_linked first). The REAL_PASS marker reports the
+	// real-pass arm; the RECORD marker belongs to the harness-only recording
+	// smoke opt-in so a real-pass success is never misreported as a
+	// recording-smoke run and vice versa.
+	if (GLOBAL_GET("rendering/rurix_accel/passes/particles_copy/dispatch_real_pass")) {
+		print_line("RXGD_GODOT_RUNTIME_PARTICLES_COPY_REAL_PASS: pass=RXGD_PASS_PARTICLES_COPY dispatched=1");
+	}
+	if (GLOBAL_GET("rendering/rurix_accel/passes/particles_copy/dispatch_recording_smoke")) {
+		print_line("RXGD_GODOT_RUNTIME_PARTICLES_COPY_RECORD: pass=RXGD_PASS_PARTICLES_COPY recorded=1");
+	}
 	return true;
 }
 
diff --git a/modules/rurix_accel/rurix_accel.h b/modules/rurix_accel/rurix_accel.h
index e2c1af4..d5f9e21 100644
--- a/modules/rurix_accel/rurix_accel.h
+++ b/modules/rurix_accel/rurix_accel.h
@@ -67,6 +67,16 @@
 // diagnostic unless every check passes AND the d3d12-recording-shim real
 // dispatch path is linked and completes.
 #define RXGD_CAP_TAA_RESOLVE_REAL_PASS 64u
+// GRX-013 opt-in particles_copy real-pass arm carried in RxGdCaps.flags (ABI
+// v1, no struct layout change; bridge value 1 << 7). Set only when the
+// default-false rendering/rurix_accel/passes/particles_copy/dispatch_real_pass
+// opt-in is enabled. Setting it never on its own makes the bridge return
+// RXGD_STATUS_OK: the fail-closed ParticlesCopyGate runs preflight ->
+// eligibility -> binding-kind (structured_buffer/rwstructured_buffer) ->
+// math-parity -> linked-dispatch checks and returns RXGD_STATUS_FALLBACK with
+// an RXGD_PARTICLES_COPY_REAL_PASS_BLOCKED diagnostic unless every check passes
+// AND the d3d12-recording-shim real dispatch path is linked and completes.
+#define RXGD_CAP_PARTICLES_COPY_REAL_PASS 128u
 
 typedef struct RxGdCaps {
 	uint32_t abi_version;
diff --git a/servers/rendering/renderer_rd/storage_rd/particles_storage.cpp b/servers/rendering/renderer_rd/storage_rd/particles_storage.cpp
index 9179e29..325d00e 100644
--- a/servers/rendering/renderer_rd/storage_rd/particles_storage.cpp
+++ b/servers/rendering/renderer_rd/storage_rd/particles_storage.cpp
@@ -1377,6 +1377,21 @@ void ParticlesStorage::particles_set_view_axis(RID p_particles, const Vector3 &p
 			const uint32_t rurix_src_bytes = rurix_particles_count * 112u;
 			const uint32_t rurix_dst_bytes = rurix_particles_count * 80u;
 			rurix_recorded_particles_copy = D3D12Hooks::get_singleton()->try_record_particles_copy(rurix_src_handle, rurix_dst_handle, rurix_src_bytes, rurix_dst_bytes, (const uint8_t *)&copy_push_constant, (uint32_t)sizeof(ParticlesShader::CopyPushConstant));
+			if (rurix_recorded_particles_copy) {
+				// GRX-013 result writeback SCAFFOLD (0010-level). The Rurix bridge
+				// dispatched the COPY_MODE_FILL_INSTANCES kernel into the real
+				// Transforms SSBO destination ID3D12Resource*, so the fill-instances
+				// subset result is physically written into the instance buffer.
+				// Record that writeback with a machine-readable marker, then keep the
+				// FULL native Godot particles copy dispatch as the continuation/
+				// backstop: the kernel covers only the ALIGN_DISABLED/ALIGN_BILLBOARD
+				// 3D subset (no 2D, sort, lifetime reindex, trail, or userdata) and
+				// GPU math parity is still pending measurement, so the native
+				// dispatch re-fills every instance and the render can never change
+				// while this scaffold is in place.
+				print_line("RXGD_GODOT_RUNTIME_PARTICLES_COPY_REAL_PASS_WRITEBACK: dst=particle_instance_buffer native_continuation=active scaffold=1");
+				rurix_recorded_particles_copy = false;
+			}
 		}
 	}
 #endif
-- 
