diff --git a/modules/rurix_accel/rurix_accel.cpp b/modules/rurix_accel/rurix_accel.cpp
index 5ff8256..f2a80c5 100644
--- a/modules/rurix_accel/rurix_accel.cpp
+++ b/modules/rurix_accel/rurix_accel.cpp
@@ -1150,4 +1150,125 @@ bool RurixAccelD3D12Hooks::try_record_tonemap_rd_native(RID p_source_color, RID
 	return true;
 }
 
+bool RurixAccelD3D12Hooks::try_record_ssao_blur_rd_native(int64_t p_compute_list, RID p_source_slice, RID p_dest_slice, Size2i p_slice_size, float p_edge_sharpness, float p_half_screen_pixel_size_x, float p_half_screen_pixel_size_y) {
+	// GRX Route B rd_native ssao_blur: an in-frame RD-native compute replacement
+	// for one SMART edge-aware blur slice. Like the tonemap rd_native path this
+	// does NOT go through the Rurix rxgd bridge/shim (session/record_pass); it
+	// drives the main RenderingDevice directly so the Rurix ssao_blur kernel runs
+	// as a first-class dispatch inside the frame graph. Unlike tonemap, the SSAO
+	// compute list is opened ONCE by generate_ssao around the whole
+	// gather/blur/interleave chain, so this records onto the caller's already-open
+	// list (p_compute_list) and MUST NOT begin/end its own. Every early return
+	// below keeps the native SMART blur dispatch for this slice (fail-closed). The
+	// caller only reaches here when the backend selector is 2 (rd_native).
+	RenderingDevice *rd = RenderingDevice::get_singleton();
+	if (rd == nullptr) {
+		return false;
+	}
+	if (rd_native_ssao_blur_load_failed) {
+		// A prior container load / pipeline compile failed; do not retry every
+		// frame (and do not spam diagnostics). The native SSAO blur path renders.
+		return false;
+	}
+	if (!p_source_slice.is_valid() || !p_dest_slice.is_valid()) {
+		return false;
+	}
+	if (p_slice_size.x <= 0 || p_slice_size.y <= 0) {
+		return false;
+	}
+	// Usage-bits preflight: the deinterleaved source slice must be sampleable
+	// (SRV t0) and the ping-pong destination slice must be storage-writable
+	// (UAV u0). Both SSAO deinterleaved textures carry SAMPLING_BIT | STORAGE_BIT
+	// today (they ping-pong as both sampler-source and image-dest); this preflight
+	// guards against a future Godot snapshot changing those flags and fails closed
+	// rather than letting uniform_set_create assert mid-frame.
+	const RenderingDevice::TextureFormat src_format = rd->texture_get_format(p_source_slice);
+	const RenderingDevice::TextureFormat dst_format = rd->texture_get_format(p_dest_slice);
+	if ((src_format.usage_bits & RenderingDevice::TEXTURE_USAGE_SAMPLING_BIT) == 0) {
+		return false;
+	}
+	if ((dst_format.usage_bits & RenderingDevice::TEXTURE_USAGE_STORAGE_BIT) == 0) {
+		return false;
+	}
+	// Lazily build the compute pipeline the first time backend == 2 is exercised:
+	// read the Rurix container bytes, hand them to shader_create_from_bytecode
+	// (-> shader_create_from_container in the D3D12 driver; the driver consumes the
+	// container's DXIL + RTS0 verbatim), and create the compute pipeline
+	// (-> CreateRootSignature + PSO). Any failure latches rd_native_ssao_blur_load_failed
+	// so it is not retried per frame.
+	if (!rd_native_ssao_blur_shader.is_valid() || !rd_native_ssao_blur_pipeline.is_valid()) {
+		const String container_path = GLOBAL_GET("rendering/rurix_accel/passes/ssao_blur/rd_container_path");
+		if (container_path.is_empty()) {
+			// No container configured: keep rd_native fail-closed (disabled).
+			rd_native_ssao_blur_load_failed = true;
+			return false;
+		}
+		const Vector<uint8_t> container_bytes = FileAccess::get_file_as_bytes(container_path);
+		if (container_bytes.is_empty()) {
+			rd_native_ssao_blur_load_failed = true;
+			print_verbose(vformat("RurixAccel: rd_native ssao_blur container '%s' missing or empty; native SSAO blur path remains active.", container_path));
+			return false;
+		}
+		const RID shader = rd->shader_create_from_bytecode(container_bytes);
+		if (!shader.is_valid()) {
+			rd_native_ssao_blur_load_failed = true;
+			print_verbose("RurixAccel: rd_native ssao_blur shader_create_from_bytecode failed; native SSAO blur path remains active.");
+			return false;
+		}
+		const RID pipeline = rd->compute_pipeline_create(shader);
+		if (!pipeline.is_valid()) {
+			rd->free_rid(shader);
+			rd_native_ssao_blur_load_failed = true;
+			print_verbose("RurixAccel: rd_native ssao_blur compute_pipeline_create failed; native SSAO blur path remains active.");
+			return false;
+		}
+		rd_native_ssao_blur_shader = shader;
+		rd_native_ssao_blur_pipeline = pipeline;
+		if (!rd_native_ssao_blur_active_logged) {
+			// One-shot marker (NOT per-frame): the RD-native SMART blur slice
+			// replacement is engaged and the native Godot SMART blur dispatch is
+			// being skipped for the replaced slices.
+			print_verbose("RXGD_RD_NATIVE_SSAO_BLUR active: backend=rd_native, in-frame SMART blur slice replacement engaged (native Godot SMART blur dispatch skipped for replaced slices).");
+			rd_native_ssao_blur_active_logged = true;
+		}
+	}
+	// Bind t0 = deinterleaved AO source slice (SRV, UNIFORM_TYPE_TEXTURE) and
+	// u0 = ping-pong destination slice (UAV, UNIFORM_TYPE_IMAGE). UniformSetCacheRD
+	// keys on the RID set and auto-invalidates the cached set when either slice is
+	// freed (resize), so no manual lifetime handling is needed.
+	const RID uniform_set = UniformSetCacheRD::get_singleton()->get_cache(
+			rd_native_ssao_blur_shader, 0,
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_TEXTURE, 0, p_source_slice),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_IMAGE, 1, p_dest_slice));
+	if (!uniform_set.is_valid()) {
+		return false;
+	}
+	// b0 root constants (28 bytes / 7 DWORDs): slice_width and slice_height as
+	// 64-bit integers (the ssao_blur kernel declares the 64-bit integer shader
+	// capability), then edge_sharpness and the two half_screen_pixel_size floats,
+	// little-endian like D3D12. This mirrors the shim path's ssao_blur packing
+	// (patch 0015).
+	uint8_t push_constants[SSAO_BLUR_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES] = {};
+	const uint64_t source_width = (uint64_t)MAX(p_slice_size.x, 0);
+	const uint64_t source_height = (uint64_t)MAX(p_slice_size.y, 0);
+	memcpy(&push_constants[0], &source_width, sizeof(source_width));
+	memcpy(&push_constants[8], &source_height, sizeof(source_height));
+	memcpy(&push_constants[16], &p_edge_sharpness, sizeof(p_edge_sharpness));
+	memcpy(&push_constants[20], &p_half_screen_pixel_size_x, sizeof(p_half_screen_pixel_size_x));
+	memcpy(&push_constants[24], &p_half_screen_pixel_size_y, sizeof(p_half_screen_pixel_size_y));
+	// Record the in-frame compute dispatch onto the caller's ALREADY-OPEN
+	// generate_ssao compute list. No compute_list_begin()/end() here (the SSAO
+	// list is opened once around the whole chain); the loop's per-pass
+	// compute_list_add_barrier handles the write->read hazards, and the main-RD
+	// draw graph tracks the uniform_set_create resources as first-class citizens.
+	const RenderingDevice::ComputeListID compute_list = (RenderingDevice::ComputeListID)p_compute_list;
+	rd->compute_list_bind_compute_pipeline(compute_list, rd_native_ssao_blur_pipeline);
+	rd->compute_list_bind_uniform_set(compute_list, uniform_set, 0);
+	rd->compute_list_set_push_constant(compute_list, push_constants, SSAO_BLUR_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES);
+	const uint32_t groups_x = (uint32_t)((MAX(p_slice_size.x, 0) + 7) / 8);
+	const uint32_t groups_y = (uint32_t)((MAX(p_slice_size.y, 0) + 7) / 8);
+	rd->compute_list_dispatch(compute_list, groups_x, groups_y, 1);
+	return true;
+}
+
 #endif // D3D12_ENABLED
