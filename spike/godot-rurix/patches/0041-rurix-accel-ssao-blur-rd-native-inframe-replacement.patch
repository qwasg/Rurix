 modules/rurix_accel/register_types.cpp        |  18 +++
 modules/rurix_accel/rurix_accel.cpp           | 121 ++++++++++++++++++
 modules/rurix_accel/rurix_accel.h             |  27 ++++
 .../renderer_rd/effects/ss_effects.cpp        |  29 ++++-
