index 605965f..0feab9b 100644
--- a/drivers/d3d12/d3d12_hooks.h
+++ b/drivers/d3d12/d3d12_hooks.h
@@ -157,5 +157,23 @@ public:
 	// this (or the absence of a hooks singleton) keep the native Godot tonemap
 	// path.
 	virtual bool try_record_tonemap_rd_native(RID p_source_color, RID p_dest_color, Size2i p_source_size, Size2i p_dest_size, float p_exposure, float p_white, float p_luminance_multiplier) { return false; }
+	// GRX Route B rd_native ssao_blur: opt-in in-frame RD-native compute
+	// replacement hook for one SMART edge-aware blur slice. Unlike the shim-path
+	// try_record_ssao_blur() above (which takes native ID3D12Resource* handles
+	// for an out-of-frame bridge dispatch), this hook takes the Godot
+	// ComputeListID of the ALREADY-OPEN generate_ssao compute list plus the
+	// Godot RID handles for the deinterleaved AO source slice (SRV t0) and the
+	// ping-pong destination slice (UAV u0), the shared 1:1 slice size, and the
+	// ssao_blur b0 scalars, so the module can build an RD compute pipeline from a
+	// Rurix shader container and record ONE slice dispatch onto the shared
+	// generate_ssao compute list (the SSAO compute list is opened once around the
+	// whole gather/blur/interleave chain, so rd_native must NOT begin/end its own
+	// list; it reuses p_compute_list and the loop's per-pass barriers). Returning
+	// true means the module recorded the real replacement for THIS slice and the
+	// native SMART blur dispatch for this slice MUST be skipped (this is a real
+	// replacement, not a scaffold). The base implementation returns false so any
+	// hooks that do not override this (or the absence of a hooks singleton) keep
+	// the native Godot SSAO blur path.
+	virtual bool try_record_ssao_blur_rd_native(int64_t p_compute_list, RID p_source_slice, RID p_dest_slice, Size2i p_slice_size, float p_edge_sharpness, float p_half_screen_pixel_size_x, float p_half_screen_pixel_size_y) { return false; }
 	static D3D12Hooks *get_singleton() { return singleton; }
 };
