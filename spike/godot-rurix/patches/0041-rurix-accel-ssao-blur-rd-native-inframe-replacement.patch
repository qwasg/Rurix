+	RID rd_native_ssao_blur_pipeline;
+	bool rd_native_ssao_blur_load_failed = false;
+	bool rd_native_ssao_blur_active_logged = false;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES = 28;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_RESOURCE_COUNT = 2;
 	// GRX-010 tonemap resource mapping (resource_mapping.md): b0 carries
@@ -323,6 +336,20 @@ public:
 	// uniform-set creation failure) returns false and the caller keeps the
 	// native Godot tonemap path (fail-closed).
 	bool try_record_tonemap_rd_native(RID p_source_color, RID p_dest_color, Size2i p_source_size, Size2i p_dest_size, float p_exposure, float p_white, float p_luminance_multiplier) override;
+	// GRX Route B rd_native ssao_blur: in-frame RD-native compute replacement for
+	// one SMART edge-aware blur slice. Lazily builds the RD compute pipeline from
+	// the Rurix container named by rendering/rurix_accel/passes/ssao_blur/rd_container_path,
+	// binds the deinterleaved AO source slice (SRV t0) and the ping-pong
+	// destination slice (UAV u0) RIDs plus the 28-byte b0 push constants, and
+	// records a ceil(size/8) compute dispatch onto the ALREADY-OPEN generate_ssao
+	// compute list (p_compute_list; it does NOT begin/end its own list). Returns
+	// true only when the slice dispatch was actually recorded (real replacement —
+	// the caller then SKIPS the native SMART blur dispatch for this slice). Any
+	// failure (RD unavailable, latched load failure, invalid RID, missing usage
+	// bits, empty/invalid container, pipeline or uniform-set creation failure)
+	// returns false and the caller keeps the native Godot SSAO blur path
+	// (fail-closed).
+	bool try_record_ssao_blur_rd_native(int64_t p_compute_list, RID p_source_slice, RID p_dest_slice, Size2i p_slice_size, float p_edge_sharpness, float p_half_screen_pixel_size_x, float p_half_screen_pixel_size_y) override;
 };
 
 #endif // D3D12_ENABLED
