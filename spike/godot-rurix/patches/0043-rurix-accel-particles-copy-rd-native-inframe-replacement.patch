@@ -1353,8 +1353,30 @@ void ParticlesStorage::particles_set_view_axis(RID p_particles, const Vector3 &p
 	RD::get_singleton()->compute_list_set_push_constant(compute_list, &copy_push_constant, sizeof(ParticlesShader::CopyPushConstant));
 
 	bool rurix_recorded_particles_copy = false;
+	bool rurix_recorded_particles_copy_rd_native = false;
 #ifdef D3D12_ENABLED
-	if (!do_sort && D3D12Hooks::get_singleton() != nullptr) {
+	// GRX Route B rd_native particles_copy (patch 0043): backend selector == 2
+	// engages the in-frame RD-native COPY_MODE_FILL_INSTANCES replacement BEFORE
+	// the shim-path gate below. It only engages for the plain 3D fill-instances
+	// subset (!do_sort AND copy_mode_2d == 0) because the Rurix particles_copy
+	// kernel covers the ALIGN_DISABLED/ALIGN_Z_BILLBOARD 3D fill-instances subset;
+	// the sort (VIEW_DEPTH) and 2D paths are out of subset and stay native. Unlike
+	// the shim path (patch 0022, which prints a writeback marker and then
+	// deliberately clears its flag so the native copy still re-fills every
+	// instance), a successful rd_native record does NOT clear its flag: the Rurix
+	// kernel's output IS the filled Transforms SSBO, so the native
+	// COPY_MODE_FILL_INSTANCES dispatch is genuinely skipped (a real replacement —
+	// one fewer native dispatch — not a scaffold). rd_native records onto the
+	// ALREADY-OPEN particles_set_view_axis compute list (opened above around the
+	// copy dispatch, so rd_native reuses compute_list and MUST NOT begin/end its
