 	RID rd_native_taa_resolve_pipeline;
 	bool rd_native_taa_resolve_load_failed = false;
 	bool rd_native_taa_resolve_active_logged = false;
+	// GRX Route B rd_native particles_copy: lazily-built RD compute pipeline for
+	// the in-frame COPY_MODE_FILL_INSTANCES replacement. Same lifetime discipline
+	// as the texture-pass members above: the shader/pipeline are created once from
+	// the Rurix container the first time backend == 2 is exercised and cached for
+	// the process lifetime; the per-frame two-buffer uniform set is cached by
+	// UniformSetCacheRD and auto-invalidated when the bound structured buffers are
+	// freed (e.g. on particle count / userdata change). rd_native_particles_copy_load_failed
+	// latches a load/compile failure so it is not retried every frame, and
+	// rd_native_particles_copy_active_logged gates the one-shot
+	// RXGD_RD_NATIVE_PARTICLES_COPY active marker (not per-frame).
+	RID rd_native_particles_copy_shader;
+	RID rd_native_particles_copy_pipeline;
+	bool rd_native_particles_copy_load_failed = false;
+	bool rd_native_particles_copy_active_logged = false;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES = 28;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_RESOURCE_COUNT = 2;
 	// GRX-010 tonemap resource mapping (resource_mapping.md): b0 carries
@@ -378,6 +392,19 @@ public:
 	// returns false and the caller keeps the native Godot TAA resolve path
 	// (fail-closed).
 	bool try_record_taa_resolve_rd_native(RID p_color, RID p_depth, RID p_velocity, RID p_prev_velocity, RID p_history, RID p_output_temp, Size2i p_internal_size, float p_disocclusion_threshold, float p_variance_dynamic) override;
+	// GRX Route B rd_native particles_copy: in-frame RD-native compute replacement
+	// for the COPY_MODE_FILL_INSTANCES particles copy dispatch. Lazily builds the RD
+	// compute pipeline from the Rurix container named by
+	// rendering/rurix_accel/passes/particles_copy/rd_container_path, binds the two
+	// structured buffers (src_particles = SRV t0, dst_instances = UAV u0) plus the
+	// 128-byte CopyPushConstant b0, and records a total-particles dispatch onto the
+	// ALREADY-OPEN particles_set_view_axis compute list (p_compute_list; it does NOT
+	// begin/end its own list). Returns true only when the dispatch was actually
+	// recorded (real replacement — the caller then SKIPS the native fill-instances
+	// dispatch). Any failure (RD unavailable, latched load failure, invalid RID,
+	// empty/invalid container, pipeline or uniform-set creation failure) returns
+	// false and the caller keeps the native Godot particles copy path (fail-closed).
+	bool try_record_particles_copy_rd_native(int64_t p_compute_list, RID p_src_particles, RID p_dst_instances, uint32_t p_total_particles, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes) override;
 };
 
 #endif // D3D12_ENABLED
