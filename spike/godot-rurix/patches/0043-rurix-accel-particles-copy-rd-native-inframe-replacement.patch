 modules/rurix_accel/rurix_accel.cpp           | 107 ++++++++++++++++++
 modules/rurix_accel/rurix_accel.h             |  27 +++++
 .../storage_rd/particles_storage.cpp          |  26 ++++-
 5 files changed, 195 insertions(+), 2 deletions(-)

diff --git a/drivers/d3d12/d3d12_hooks.h b/drivers/d3d12/d3d12_hooks.h
index b6a53cb..9bd28a1 100644
--- a/drivers/d3d12/d3d12_hooks.h
+++ b/drivers/d3d12/d3d12_hooks.h
@@ -193,5 +193,24 @@ public:
 	// The base implementation returns false so any hooks that do not override this
 	// (or the absence of a hooks singleton) keep the native Godot TAA resolve.
 	virtual bool try_record_taa_resolve_rd_native(RID p_color, RID p_depth, RID p_velocity, RID p_prev_velocity, RID p_history, RID p_output_temp, Size2i p_internal_size, float p_disocclusion_threshold, float p_variance_dynamic) { return false; }
+	// GRX Route B rd_native particles_copy: opt-in in-frame RD-native compute
+	// replacement hook for the COPY_MODE_FILL_INSTANCES particles copy dispatch.
+	// Unlike the shim-path try_record_particles_copy() above (which takes native
+	// ID3D12Resource* structured-buffer handles for an out-of-frame bridge
+	// dispatch), this hook takes the Godot ComputeListID of the ALREADY-OPEN
+	// particles_set_view_axis fill-instances compute list (particles_set_view_axis
+	// opens its own compute_list_begin() around the copy dispatch, so rd_native
+	// must NOT begin/end its own) plus the Godot RID handles for the Particles SSBO
+	// source (SRV t0 structured_buffer) and the Transforms SSBO destination (UAV u0
+	// rwstructured_buffer), the total particle count for the 1D dispatch, and the
+	// 128-byte CopyPushConstant b0 mirror, so the module can build an RD compute
+	// pipeline from a Rurix shader container and record ONE fill-instances dispatch
+	// onto the caller's compute list. Returning true means the module recorded the
+	// real replacement and the native COPY_MODE_FILL_INSTANCES dispatch MUST be
+	// skipped (this is a real replacement — one fewer native dispatch — not a
+	// scaffold). The base implementation returns false so any hooks that do not
+	// override this (or the absence of a hooks singleton) keep the native Godot
+	// particles copy path.
+	virtual bool try_record_particles_copy_rd_native(int64_t p_compute_list, RID p_src_particles, RID p_dst_instances, uint32_t p_total_particles, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes) { return false; }
 	static D3D12Hooks *get_singleton() { return singleton; }
 };
diff --git a/modules/rurix_accel/register_types.cpp b/modules/rurix_accel/register_types.cpp
index fc5f444..aeed3b2 100644
--- a/modules/rurix_accel/register_types.cpp
+++ b/modules/rurix_accel/register_types.cpp
@@ -339,6 +339,24 @@ void initialize_rurix_accel_module(ModuleInitializationLevel p_level) {
 	// hardcoded to a res:// resource so the smoke/bench harnesses can point at an
 	// absolute staging path.
 	GLOBAL_DEF_BASIC("rendering/rurix_accel/passes/taa_resolve/rd_container_path", "");
+	// GRX Route B rd_native particles_copy: three-state backend selector for the
+	// particles_copy pass, independent of the four existing shim settings
+	// (.../passes/particles_copy/enabled|dispatch_recording_smoke|dispatch_real_pass|
+	// real_pass_force_capability_downgrade), which are left untouched. Values:
+	// 0 = disabled (default; the pre-existing shim/native chain is unchanged),
