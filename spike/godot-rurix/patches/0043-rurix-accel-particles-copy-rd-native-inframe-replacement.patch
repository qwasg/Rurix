+	// the RD-native path fail-closed (no container -> native particles copy path
+	// remains active). The container path is injected here rather than hardcoded to
+	// a res:// resource so the smoke/bench harnesses can point at an absolute
+	// staging path.
+	GLOBAL_DEF_BASIC("rendering/rurix_accel/passes/particles_copy/rd_container_path", "");
 
 #if defined(D3D12_ENABLED)
 	if (GLOBAL_GET("rendering/rurix_accel/enabled")) {
diff --git a/modules/rurix_accel/rurix_accel.cpp b/modules/rurix_accel/rurix_accel.cpp
index a7c5b43..e0bdb95 100644
--- a/modules/rurix_accel/rurix_accel.cpp
+++ b/modules/rurix_accel/rurix_accel.cpp
@@ -1404,4 +1404,111 @@ bool RurixAccelD3D12Hooks::try_record_taa_resolve_rd_native(RID p_color, RID p_d
 	return true;
 }
 
+bool RurixAccelD3D12Hooks::try_record_particles_copy_rd_native(int64_t p_compute_list, RID p_src_particles, RID p_dst_instances, uint32_t p_total_particles, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes) {
+	// GRX Route B rd_native particles_copy: an in-frame RD-native compute
+	// replacement for the COPY_MODE_FILL_INSTANCES particles copy dispatch. Like
+	// the tonemap/ssao_blur/taa_resolve rd_native paths this does NOT go through the
+	// Rurix rxgd bridge/shim (session/record_pass); it drives the main
+	// RenderingDevice directly so the Rurix particles_copy kernel runs as a
+	// first-class dispatch inside the frame graph. Unlike the texture passes, the
+	// two resources are STRUCTURED BUFFERS (the buffer probe proved
+	// UNIFORM_TYPE_STORAGE_BUFFER RAW == structured equivalence at zero tolerance).
+	// particles_set_view_axis opens ONE compute list around the copy dispatch, so
+	// this records onto the caller's already-open list (p_compute_list) and MUST NOT
+	// begin/end its own. Every early return below keeps the native
+	// COPY_MODE_FILL_INSTANCES dispatch (fail-closed). The caller only reaches here
+	// when the backend selector is 2 (rd_native).
+	RenderingDevice *rd = RenderingDevice::get_singleton();
+	if (rd == nullptr) {
+		return false;
+	}
+	if (rd_native_particles_copy_load_failed) {
+		// A prior container load / pipeline compile failed; do not retry every
+		// frame (and do not spam diagnostics). The native particles copy renders.
+		return false;
+	}
+	if (!p_src_particles.is_valid() || !p_dst_instances.is_valid()) {
+		return false;
+	}
+	if (p_total_particles == 0) {
+		return false;
+	}
+	if (p_push_constants == nullptr || p_push_constant_bytes != PARTICLES_COPY_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES) {
+		// The b0 mirror must be the exact 128-byte CopyPushConstant block.
+		return false;
+	}
+	// Lazily build the compute pipeline the first time backend == 2 is exercised:
+	// read the Rurix container bytes, hand them to shader_create_from_bytecode
+	// (-> shader_create_from_container in the D3D12 driver; the driver consumes the
+	// container's DXIL + RTS0 verbatim), and create the compute pipeline
+	// (-> CreateRootSignature + PSO). Any failure latches
+	// rd_native_particles_copy_load_failed so it is not retried per frame.
+	if (!rd_native_particles_copy_shader.is_valid() || !rd_native_particles_copy_pipeline.is_valid()) {
+		const String container_path = GLOBAL_GET("rendering/rurix_accel/passes/particles_copy/rd_container_path");
+		if (container_path.is_empty()) {
+			// No container configured: keep rd_native fail-closed (disabled).
+			rd_native_particles_copy_load_failed = true;
+			return false;
+		}
+		const Vector<uint8_t> container_bytes = FileAccess::get_file_as_bytes(container_path);
+		if (container_bytes.is_empty()) {
+			rd_native_particles_copy_load_failed = true;
+			print_verbose(vformat("RurixAccel: rd_native particles_copy container '%s' missing or empty; native particles copy path remains active.", container_path));
+			return false;
+		}
+		const RID shader = rd->shader_create_from_bytecode(container_bytes);
+		if (!shader.is_valid()) {
+			rd_native_particles_copy_load_failed = true;
+			print_verbose("RurixAccel: rd_native particles_copy shader_create_from_bytecode failed; native particles copy path remains active.");
+			return false;
+		}
+		const RID pipeline = rd->compute_pipeline_create(shader);
+		if (!pipeline.is_valid()) {
+			rd->free_rid(shader);
+			rd_native_particles_copy_load_failed = true;
+			print_verbose("RurixAccel: rd_native particles_copy compute_pipeline_create failed; native particles copy path remains active.");
+			return false;
+		}
+		rd_native_particles_copy_shader = shader;
+		rd_native_particles_copy_pipeline = pipeline;
+		if (!rd_native_particles_copy_active_logged) {
+			// One-shot marker (NOT per-frame): the RD-native fill-instances
+			// replacement is engaged and the native Godot COPY_MODE_FILL_INSTANCES
+			// dispatch is being skipped (one fewer native dispatch).
+			print_verbose("RXGD_RD_NATIVE_PARTICLES_COPY active: backend=rd_native, in-frame fill-instances replacement engaged (native Godot particles copy dispatch skipped).");
+			rd_native_particles_copy_active_logged = true;
+		}
+	}
+	// Bind t0 = Particles SSBO source and u0 = Transforms SSBO destination, both as
+	// UNIFORM_TYPE_STORAGE_BUFFER (structured_buffer / rwstructured_buffer in the
+	// container). UniformSetCacheRD keys on the RID set and auto-invalidates the
+	// cached set when either buffer is freed (particle count / userdata change), so
+	// no manual lifetime handling is needed.
+	const RID uniform_set = UniformSetCacheRD::get_singleton()->get_cache(
+			rd_native_particles_copy_shader, 0,
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_STORAGE_BUFFER, 0, p_src_particles),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_STORAGE_BUFFER, 1, p_dst_instances));
+	if (!uniform_set.is_valid()) {
+		return false;
+	}
+	// b0 root constants (128 bytes / 32 DWORDs): the raw ParticlesShader::
+	// CopyPushConstant mirror is passed through verbatim. Unlike the texture passes,
+	// particles_copy carries no i64 push-constant fields.
+	uint8_t push_constants[PARTICLES_COPY_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES] = {};
+	memcpy(push_constants, p_push_constants, PARTICLES_COPY_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES);
+	// Record the in-frame compute dispatch onto the caller's ALREADY-OPEN
+	// particles_set_view_axis compute list. No compute_list_begin()/end() here (the
+	// list is opened once around the copy dispatch); compute_list_dispatch_threads
+	// divides the total particle count by the container's local group size, and the
+	// main-RD draw graph tracks the uniform_set_create resources as first-class
+	// citizens and inserts the required barriers automatically (no submit()/sync() —
+	// that is a local-RD-only concept).
+	const RenderingDevice::ComputeListID compute_list = (RenderingDevice::ComputeListID)p_compute_list;
+	rd->compute_list_bind_compute_pipeline(compute_list, rd_native_particles_copy_pipeline);
+	rd->compute_list_bind_uniform_set(compute_list, uniform_set, 0);
+	rd->compute_list_set_push_constant(compute_list, push_constants, PARTICLES_COPY_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES);
+	rd->compute_list_dispatch_threads(compute_list, p_total_particles, 1, 1);
+	return true;
+}
+
 #endif // D3D12_ENABLED
