+		rurix_recorded_particles_copy_rd_native = D3D12Hooks::get_singleton()->try_record_particles_copy_rd_native((int64_t)compute_list, particles->particle_buffer, particles->particle_instance_buffer, copy_push_constant.total_particles, (const uint8_t *)&copy_push_constant, (uint32_t)sizeof(ParticlesShader::CopyPushConstant));
+	}
+	if (!rurix_recorded_particles_copy_rd_native && !do_sort && D3D12Hooks::get_singleton() != nullptr) {
 		// GRX-013 runtime resource binding gate (0005/0007-level in one slice).
 		// Only the plain COPY_MODE_FILL_INSTANCES subset (no sort buffer, so
 		// !do_sort) is in scope. Resolve the real D3D12 ID3D12Resource* native
@@ -1403,7 +1425,7 @@ void ParticlesStorage::particles_set_view_axis(RID p_particles, const Vector3 &p
 		}
 	}
 #endif
-	if (!rurix_recorded_particles_copy) {
