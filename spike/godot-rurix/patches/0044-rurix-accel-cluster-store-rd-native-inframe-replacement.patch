diff --git a/drivers/d3d12/d3d12_hooks.h b/drivers/d3d12/d3d12_hooks.h
index 9bd28a1..fa65fc8 100644
--- a/drivers/d3d12/d3d12_hooks.h
+++ b/drivers/d3d12/d3d12_hooks.h
@@ -212,5 +212,24 @@ public:
 	// override this (or the absence of a hooks singleton) keep the native Godot
 	// particles copy path.
 	virtual bool try_record_particles_copy_rd_native(int64_t p_compute_list, RID p_src_particles, RID p_dst_instances, uint32_t p_total_particles, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes) { return false; }
+	// GRX Route B rd_native cluster_store: opt-in in-frame RD-native compute
+	// replacement hook for the cluster_store compute merge (pack) dispatch. Unlike
+	// the shim-path try_record_cluster_store() above (which takes native
+	// ID3D12Resource* structured-buffer handles for an out-of-frame bridge
+	// dispatch), this hook takes the Godot ComputeListID of the ALREADY-OPEN
+	// bake_cluster store compute list (bake_cluster opens one list around the store
+	// dispatch, so rd_native must NOT begin/end its own) plus the three Godot
+	// structured-buffer RID handles in the container's binding order (cluster_render
+	// = SRV t0, render_elements = SRV t1, cluster_store = UAV u0), the cluster
+	// screen size for the 2D dispatch, and the 32-byte ClusterStore::PushConstant
+	// b0 mirror, so the module can build an RD compute pipeline from a Rurix shader
+	// container and record ONE store dispatch onto the caller's compute list.
+	// Returning true means the module recorded the real replacement and the native
+	// cluster_store dispatch MUST be skipped (this is a real replacement — one fewer
+	// native dispatch — not a scaffold; this is where GRX-014 becomes a real
+	// replacement). The base implementation returns false so any hooks that do not
+	// override this (or the absence of a hooks singleton) keep the native Godot
+	// cluster store path.
+	virtual bool try_record_cluster_store_rd_native(int64_t p_compute_list, RID p_cluster_render, RID p_render_elements, RID p_cluster_store, Size2i p_screen_size, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes) { return false; }
 	static D3D12Hooks *get_singleton() { return singleton; }
 };
