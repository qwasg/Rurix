@@ -202,6 +202,20 @@ class RurixAccelD3D12Hooks : public D3D12Hooks {
 	RID rd_native_particles_copy_pipeline;
 	bool rd_native_particles_copy_load_failed = false;
 	bool rd_native_particles_copy_active_logged = false;
+	// GRX Route B rd_native cluster_store: lazily-built RD compute pipeline for the
+	// in-frame cluster store (pack) replacement. Same lifetime discipline as the
+	// members above: the shader/pipeline are created once from the Rurix container
+	// the first time backend == 2 is exercised and cached for the process lifetime;
+	// the per-frame three-buffer uniform set is cached by UniformSetCacheRD and
+	// auto-invalidated when the bound structured buffers are freed (e.g. on a
+	// cluster screen-size / element-count change). rd_native_cluster_store_load_failed
+	// latches a load/compile failure so it is not retried every frame, and
+	// rd_native_cluster_store_active_logged gates the one-shot
+	// RXGD_RD_NATIVE_CLUSTER_STORE active marker (not per-frame).
+	RID rd_native_cluster_store_shader;
+	RID rd_native_cluster_store_pipeline;
+	bool rd_native_cluster_store_load_failed = false;
+	bool rd_native_cluster_store_active_logged = false;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES = 28;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_RESOURCE_COUNT = 2;
 	// GRX-010 tonemap resource mapping (resource_mapping.md): b0 carries
@@ -405,6 +419,20 @@ public:
 	// empty/invalid container, pipeline or uniform-set creation failure) returns
 	// false and the caller keeps the native Godot particles copy path (fail-closed).
 	bool try_record_particles_copy_rd_native(int64_t p_compute_list, RID p_src_particles, RID p_dst_instances, uint32_t p_total_particles, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes) override;
+	// GRX Route B rd_native cluster_store: in-frame RD-native compute replacement
+	// for the cluster_store (pack) dispatch. Lazily builds the RD compute pipeline
+	// from the Rurix container named by
+	// rendering/rurix_accel/passes/cluster_store/rd_container_path, binds the three
+	// structured buffers (cluster_render = SRV t0, render_elements = SRV t1,
+	// cluster_store = UAV u0) plus the 32-byte ClusterStore::PushConstant b0, and
+	// records a screen-size dispatch onto the ALREADY-OPEN bake_cluster store
+	// compute list (p_compute_list; it does NOT begin/end its own list). Returns
+	// true only when the dispatch was actually recorded (real replacement — the
+	// caller then SKIPS the native cluster_store dispatch). Any failure (RD
+	// unavailable, latched load failure, invalid RID, empty/invalid container,
+	// pipeline or uniform-set creation failure) returns false and the caller keeps
+	// the native Godot cluster store path (fail-closed).
+	bool try_record_cluster_store_rd_native(int64_t p_compute_list, RID p_cluster_render, RID p_render_elements, RID p_cluster_store, Size2i p_screen_size, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes) override;
 };
 
 #endif // D3D12_ENABLED
