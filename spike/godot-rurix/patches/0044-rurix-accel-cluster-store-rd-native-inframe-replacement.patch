--- a/modules/rurix_accel/register_types.cpp
+++ b/modules/rurix_accel/register_types.cpp
@@ -357,6 +357,24 @@ void initialize_rurix_accel_module(ModuleInitializationLevel p_level) {
 	// a res:// resource so the smoke/bench harnesses can point at an absolute
 	// staging path.
 	GLOBAL_DEF_BASIC("rendering/rurix_accel/passes/particles_copy/rd_container_path", "");
+	// GRX Route B rd_native cluster_store: three-state backend selector for the
+	// cluster_store pass, independent of the four existing shim settings
+	// (.../passes/cluster_store/enabled|dispatch_recording_smoke|dispatch_real_pass|
+	// real_pass_force_capability_downgrade), which are left untouched. Values:
+	// 0 = disabled (default; the pre-existing shim/native chain is unchanged),
