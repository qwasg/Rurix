diff --git a/modules/rurix_accel/rurix_accel.cpp b/modules/rurix_accel/rurix_accel.cpp
index e0bdb95..e1d1679 100644
--- a/modules/rurix_accel/rurix_accel.cpp
+++ b/modules/rurix_accel/rurix_accel.cpp
@@ -1511,4 +1511,111 @@ bool RurixAccelD3D12Hooks::try_record_particles_copy_rd_native(int64_t p_compute
 	return true;
 }
 
+bool RurixAccelD3D12Hooks::try_record_cluster_store_rd_native(int64_t p_compute_list, RID p_cluster_render, RID p_render_elements, RID p_cluster_store, Size2i p_screen_size, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes) {
+	// GRX Route B rd_native cluster_store: an in-frame RD-native compute
+	// replacement for the cluster_store (pack) dispatch. Like the other rd_native
+	// paths this does NOT go through the Rurix rxgd bridge/shim (session/record_pass);
+	// it drives the main RenderingDevice directly so the Rurix cluster_store kernel
+	// runs as a first-class dispatch inside the frame graph. The three resources are
+	// STRUCTURED BUFFERS (the buffer probe proved UNIFORM_TYPE_STORAGE_BUFFER RAW ==
+	// structured equivalence at zero tolerance). bake_cluster opens ONE compute list
+	// around the store dispatch, so this records onto the caller's already-open list
+	// (p_compute_list) and MUST NOT begin/end its own. Every early return below keeps
+	// the native cluster_store dispatch (fail-closed). The caller only reaches here
+	// when the backend selector is 2 (rd_native).
+	RenderingDevice *rd = RenderingDevice::get_singleton();
+	if (rd == nullptr) {
+		return false;
+	}
+	if (rd_native_cluster_store_load_failed) {
+		// A prior container load / pipeline compile failed; do not retry every
+		// frame (and do not spam diagnostics). The native cluster store renders.
+		return false;
+	}
+	if (!p_cluster_render.is_valid() || !p_render_elements.is_valid() || !p_cluster_store.is_valid()) {
+		return false;
+	}
+	if (p_screen_size.x <= 0 || p_screen_size.y <= 0) {
+		return false;
+	}
+	if (p_push_constants == nullptr || p_push_constant_bytes != CLUSTER_STORE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES) {
+		// The b0 mirror must be the exact 32-byte ClusterStore::PushConstant block.
+		return false;
+	}
+	// Lazily build the compute pipeline the first time backend == 2 is exercised:
+	// read the Rurix container bytes, hand them to shader_create_from_bytecode
+	// (-> shader_create_from_container in the D3D12 driver; the driver consumes the
+	// container's DXIL + RTS0 verbatim), and create the compute pipeline
+	// (-> CreateRootSignature + PSO). Any failure latches
+	// rd_native_cluster_store_load_failed so it is not retried per frame.
+	if (!rd_native_cluster_store_shader.is_valid() || !rd_native_cluster_store_pipeline.is_valid()) {
+		const String container_path = GLOBAL_GET("rendering/rurix_accel/passes/cluster_store/rd_container_path");
+		if (container_path.is_empty()) {
+			// No container configured: keep rd_native fail-closed (disabled).
+			rd_native_cluster_store_load_failed = true;
+			return false;
+		}
+		const Vector<uint8_t> container_bytes = FileAccess::get_file_as_bytes(container_path);
+		if (container_bytes.is_empty()) {
+			rd_native_cluster_store_load_failed = true;
+			print_verbose(vformat("RurixAccel: rd_native cluster_store container '%s' missing or empty; native cluster store path remains active.", container_path));
+			return false;
+		}
+		const RID shader = rd->shader_create_from_bytecode(container_bytes);
+		if (!shader.is_valid()) {
+			rd_native_cluster_store_load_failed = true;
+			print_verbose("RurixAccel: rd_native cluster_store shader_create_from_bytecode failed; native cluster store path remains active.");
+			return false;
+		}
+		const RID pipeline = rd->compute_pipeline_create(shader);
+		if (!pipeline.is_valid()) {
+			rd->free_rid(shader);
+			rd_native_cluster_store_load_failed = true;
+			print_verbose("RurixAccel: rd_native cluster_store compute_pipeline_create failed; native cluster store path remains active.");
+			return false;
+		}
+		rd_native_cluster_store_shader = shader;
+		rd_native_cluster_store_pipeline = pipeline;
+		if (!rd_native_cluster_store_active_logged) {
+			// One-shot marker (NOT per-frame): the RD-native cluster store
+			// replacement is engaged and the native Godot cluster_store dispatch is
+			// being skipped (one fewer native dispatch; GRX-014 becomes a real
+			// replacement here, no longer a scaffold).
+			print_verbose("RXGD_RD_NATIVE_CLUSTER_STORE active: backend=rd_native, in-frame cluster store replacement engaged (native Godot cluster_store dispatch skipped).");
+			rd_native_cluster_store_active_logged = true;
+		}
+	}
+	// Bind t0 = cluster_render_buffer, t1 = element_buffer (both SRV), u0 =
+	// cluster_buffer (UAV), all as UNIFORM_TYPE_STORAGE_BUFFER in the container's
+	// binding order (0, 1, 2). UniformSetCacheRD keys on the RID set and
+	// auto-invalidates the cached set when any buffer is freed, so no manual
+	// lifetime handling is needed.
+	const RID uniform_set = UniformSetCacheRD::get_singleton()->get_cache(
+			rd_native_cluster_store_shader, 0,
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_STORAGE_BUFFER, 0, p_cluster_render),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_STORAGE_BUFFER, 1, p_render_elements),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_STORAGE_BUFFER, 2, p_cluster_store));
+	if (!uniform_set.is_valid()) {
+		return false;
+	}
+	// b0 root constants (32 bytes / 8 DWORDs): the raw ClusterStore::PushConstant
+	// mirror is passed through verbatim. cluster_store carries no i64 push-constant
+	// fields.
+	uint8_t push_constants[CLUSTER_STORE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES] = {};
+	memcpy(push_constants, p_push_constants, CLUSTER_STORE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES);
+	// Record the in-frame compute dispatch onto the caller's ALREADY-OPEN
+	// bake_cluster store compute list. No compute_list_begin()/end() here (the list
+	// is opened once around the store dispatch); compute_list_dispatch_threads
+	// divides the screen size by the container's 8x8 local group size, and the
+	// main-RD draw graph tracks the uniform_set_create resources as first-class
+	// citizens and inserts the required barriers automatically (no submit()/sync() —
+	// that is a local-RD-only concept).
+	const RenderingDevice::ComputeListID compute_list = (RenderingDevice::ComputeListID)p_compute_list;
+	rd->compute_list_bind_compute_pipeline(compute_list, rd_native_cluster_store_pipeline);
+	rd->compute_list_bind_uniform_set(compute_list, uniform_set, 0);
+	rd->compute_list_set_push_constant(compute_list, push_constants, CLUSTER_STORE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES);
+	rd->compute_list_dispatch_threads(compute_list, (uint32_t)MAX(p_screen_size.x, 0), (uint32_t)MAX(p_screen_size.y, 0), 1);
+	return true;
+}
+
 #endif // D3D12_ENABLED
