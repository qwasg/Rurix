+	// bridge status such as RXGD_STATUS_FALLBACK from the fail-closed
+	// FusedPostChainGate) returns false and the caller must keep the native
+	// Godot luminance_reduction + tonemap chain.
+	bool try_record_fused_post_chain(uint64_t p_src_color_native_handle, uint64_t p_lum_source_native_handle, uint64_t p_prev_luminance_native_handle, uint64_t p_dst_color_native_handle, uint64_t p_dst_luminance_native_handle, uint32_t p_source_width, uint32_t p_source_height, uint32_t p_lum_source_width, uint32_t p_lum_source_height, float p_max_luminance, float p_min_luminance, float p_exposure_adjust, float p_exposure, float p_white, float p_luminance_multiplier, float p_first_frame, float p_auto_exposure_scale) override;
 };
 
 #endif // D3D12_ENABLED
