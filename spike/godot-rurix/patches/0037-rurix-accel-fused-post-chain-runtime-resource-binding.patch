@@ -931,13 +931,16 @@ bool RurixAccelD3D12Hooks::try_record_cluster_store(uint64_t p_cluster_render_na
 	return true;
 }
 
-bool RurixAccelD3D12Hooks::try_record_fused_post_chain() {
-	// GRX-019 gate: every early return below means the caller must keep the
-	// native Godot luminance_reduction + tonemap chain. This is 0002-level
-	// module wiring: the call carries no resource bindings (native handle
-	// mapping belongs to patch 0037), and the fail-closed bridge
-	// FusedPostChainGate always returns RXGD_STATUS_FALLBACK for
-	// RXGD_PASS_FUSED_POST_CHAIN today, so the native chain keeps rendering.
+bool RurixAccelD3D12Hooks::try_record_fused_post_chain(uint64_t p_src_color_native_handle, uint64_t p_lum_source_native_handle, uint64_t p_prev_luminance_native_handle, uint64_t p_dst_color_native_handle, uint64_t p_dst_luminance_native_handle, uint32_t p_source_width, uint32_t p_source_height, uint32_t p_lum_source_width, uint32_t p_lum_source_height, float p_max_luminance, float p_min_luminance, float p_exposure_adjust, float p_exposure, float p_white, float p_luminance_multiplier, float p_first_frame, float p_auto_exposure_scale) {
+	// GRX-019 runtime resource binding gate: every early return below means
+	// the caller must keep the native Godot luminance_reduction + tonemap
+	// chain. This is the 0005/0007-level wiring in one slice: the call now
+	// carries the real fused binding (native ID3D12Resource* handles,
+	// dimensions, and the 64-byte b0 root constants) so the fail-closed bridge
+	// FusedPostChainGate can run its runtime binding preflight. The default
+	// record path (no real-pass opt-in) still always returns
+	// RXGD_STATUS_FALLBACK for RXGD_PASS_FUSED_POST_CHAIN, so the native chain
+	// keeps rendering.
 	if (!GLOBAL_GET("rendering/rurix_accel/passes/fused_post_chain/enabled")) {
 		// manual_disabled: the pass is opt-in and defaults to disabled.
 		return false;
@@ -947,10 +950,58 @@ bool RurixAccelD3D12Hooks::try_record_fused_post_chain() {
 		// unsupported_device for this pass.
 		return false;
 	}
-	const int32_t rc = rxgd_record_pass(session, RXGD_PASS_FUSED_POST_CHAIN, nullptr, 0, nullptr, 0);
+	if (p_src_color_native_handle == 0 || p_lum_source_native_handle == 0 || p_prev_luminance_native_handle == 0 || p_dst_color_native_handle == 0 || p_dst_luminance_native_handle == 0) {
+		// A zero native handle means RenderingDevice could not resolve a real
+		// ID3D12Resource*; keep the native Godot chain instead of binding a
+		// null resource.
+		return false;
+	}
+	// Marshal the fused binding for the bridge. native_handle carries the real
+	// D3D12 ID3D12Resource* resolved from RenderingDevice::get_driver_resource,
+	// not a logical Godot RID id. Slot order: src_color (SRV t0), lum_source
+	// (SRV t1), prev_luminance (SRV t2), dst_color (UAV u0), dst_luminance (UAV
+	// u1).
+	RxGdResource resources[FUSED_POST_CHAIN_RESOURCE_MAPPING_RESOURCE_COUNT] = {};
+	const uint64_t handles[FUSED_POST_CHAIN_RESOURCE_MAPPING_RESOURCE_COUNT] = { p_src_color_native_handle, p_lum_source_native_handle, p_prev_luminance_native_handle, p_dst_color_native_handle, p_dst_luminance_native_handle };
+	const uint32_t widths[FUSED_POST_CHAIN_RESOURCE_MAPPING_RESOURCE_COUNT] = { p_source_width, p_lum_source_width, 1u, p_source_width, 1u };
+	const uint32_t heights[FUSED_POST_CHAIN_RESOURCE_MAPPING_RESOURCE_COUNT] = { p_source_height, p_lum_source_height, 1u, p_source_height, 1u };
+	for (uint32_t i = 0; i < FUSED_POST_CHAIN_RESOURCE_MAPPING_RESOURCE_COUNT; i++) {
+		resources[i].abi_version = RXGD_ABI_VERSION;
+		resources[i].struct_size = (uint32_t)sizeof(RxGdResource);
+		resources[i].resource_type = RXGD_RESOURCE_TEXTURE;
+		resources[i].width = widths[i];
+		resources[i].height = heights[i];
+		resources[i].depth = 1;
+		resources[i].mip_levels = 1;
+		resources[i].native_handle = handles[i];
+	}
+	// b0 root constants (64 bytes / 16 DWORDs): source_width, source_height,
+	// lum_source_width, lum_source_height as 64-bit integers (the fused kernel
+	// declares the 64-bit integer shader capability), then max_luminance,
+	// min_luminance, exposure_adjust, exposure, white, luminance_multiplier,
+	// first_frame, auto_exposure_scale as 32-bit floats, little-endian like
+	// D3D12.
+	uint8_t push_constants[FUSED_POST_CHAIN_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES] = {};
+	const uint64_t source_width = p_source_width;
+	const uint64_t source_height = p_source_height;
+	const uint64_t lum_source_width = p_lum_source_width;
+	const uint64_t lum_source_height = p_lum_source_height;
+	memcpy(&push_constants[0], &source_width, sizeof(source_width));
+	memcpy(&push_constants[8], &source_height, sizeof(source_height));
+	memcpy(&push_constants[16], &lum_source_width, sizeof(lum_source_width));
+	memcpy(&push_constants[24], &lum_source_height, sizeof(lum_source_height));
+	memcpy(&push_constants[32], &p_max_luminance, sizeof(p_max_luminance));
+	memcpy(&push_constants[36], &p_min_luminance, sizeof(p_min_luminance));
+	memcpy(&push_constants[40], &p_exposure_adjust, sizeof(p_exposure_adjust));
+	memcpy(&push_constants[44], &p_exposure, sizeof(p_exposure));
+	memcpy(&push_constants[48], &p_white, sizeof(p_white));
+	memcpy(&push_constants[52], &p_luminance_multiplier, sizeof(p_luminance_multiplier));
+	memcpy(&push_constants[56], &p_first_frame, sizeof(p_first_frame));
+	memcpy(&push_constants[60], &p_auto_exposure_scale, sizeof(p_auto_exposure_scale));
+	const int32_t rc = rxgd_record_pass(session, RXGD_PASS_FUSED_POST_CHAIN, resources, FUSED_POST_CHAIN_RESOURCE_MAPPING_RESOURCE_COUNT, push_constants, FUSED_POST_CHAIN_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES);
 	if (rc != RXGD_STATUS_OK) {
 		if (!fused_post_chain_fallback_logged) {
-			print_verbose(vformat("RurixAccel: fused_post_chain fallback rc=%d; Godot native luminance_reduction + tonemap chain remains active.", rc));
+			print_verbose(vformat("RurixAccel: fused_post_chain native resource handle mapping fallback rc=%d; Godot native luminance_reduction + tonemap chain remains active.", rc));
 			fused_post_chain_fallback_logged = true;
 		}
 		return false;
