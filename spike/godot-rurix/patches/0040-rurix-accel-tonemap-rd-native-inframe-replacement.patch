+	// GRX Route B rd_native tonemap: opt-in in-frame RD-native compute
+	// replacement hook. Unlike the shim-path try_record_tonemap() above (which
+	// takes native ID3D12Resource* handles for an out-of-frame bridge dispatch),
+	// this hook takes Godot RID handles for the HDR source color texture and the
+	// LDR destination texture plus their sizes and the tonemap b0 scalars, so the
+	// module can build an RD compute pipeline from a Rurix shader container and
+	// dispatch it as a first-class in-frame pass on the main RenderingDevice
+	// (compute_list within _render_buffers_post_process_and_tonemap; the draw
+	// graph's ResourceTracker inserts the barriers). Returning true means the
+	// module has recorded the real in-frame replacement and the native Godot
+	// tonemapper MUST be skipped (this is a real replacement, not a scaffold).
+	// The base implementation returns false so any hooks that do not override
+	// this (or the absence of a hooks singleton) keep the native Godot tonemap
+	// path.
+	virtual bool try_record_tonemap_rd_native(RID p_source_color, RID p_dest_color, Size2i p_source_size, Size2i p_dest_size, float p_exposure, float p_white, float p_luminance_multiplier) { return false; }
 	static D3D12Hooks *get_singleton() { return singleton; }
 };
