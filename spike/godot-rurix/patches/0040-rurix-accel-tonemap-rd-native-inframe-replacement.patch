 modules/rurix_accel/rurix_accel.cpp           | 120 ++++++++++++++++++
 modules/rurix_accel/rurix_accel.h             |  25 ++++
 .../renderer_rd/renderer_scene_render_rd.cpp  |  23 +++-
 5 files changed, 202 insertions(+), 2 deletions(-)

