 	bool gpu_culling_fallback_logged = false;
+	// GRX Route B rd_native tonemap: lazily-built RD compute pipeline for the
+	// in-frame tonemap replacement. The shader/pipeline are created once from
+	// the Rurix container the first time backend == 2 is exercised and cached
