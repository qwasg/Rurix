+	// active marker (not per-frame).
+	RID rd_native_tonemap_shader;
+	RID rd_native_tonemap_pipeline;
+	bool rd_native_tonemap_load_failed = false;
+	bool rd_native_tonemap_active_logged = false;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES = 28;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_RESOURCE_COUNT = 2;
 	// GRX-010 tonemap resource mapping (resource_mapping.md): b0 carries
@@ -298,6 +311,18 @@ public:
 	// RXGD_STATUS_FALLBACK from the fail-closed GpuCullingGate) returns false and
 	// the caller must keep the native Godot CPU-driven command-buffer path.
 	bool try_record_gpu_culling(uint64_t p_transforms_native_handle, uint64_t p_commands_native_handle, uint64_t p_visibility_native_handle, uint32_t p_transforms_size_bytes, uint32_t p_commands_size_bytes, uint32_t p_visibility_size_bytes, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes) override;
+	// GRX Route B rd_native tonemap: in-frame RD-native compute replacement.
+	// Lazily builds the RD compute pipeline from the Rurix container named by
+	// rendering/rurix_accel/passes/tonemap/rd_container_path, binds the HDR
+	// source color (SRV t0) and LDR destination (UAV u0) texture RIDs plus the
+	// 28-byte b0 push constants, and dispatches ceil(dest/8) compute groups on
+	// the main RenderingDevice's active frame. Returns true only when the pass
+	// was actually recorded (real replacement — the caller then SKIPS the native
+	// Godot tonemapper). Any failure (RD unavailable, latched load failure,
+	// invalid RID, missing usage bits, empty/invalid container, pipeline or
+	// uniform-set creation failure) returns false and the caller keeps the
+	// native Godot tonemap path (fail-closed).
+	bool try_record_tonemap_rd_native(RID p_source_color, RID p_dest_color, Size2i p_source_size, Size2i p_dest_size, float p_exposure, float p_white, float p_luminance_multiplier) override;
 };
 
 #endif // D3D12_ENABLED
