+bool RurixAccelD3D12Hooks::try_record_tonemap_rd_native(RID p_source_color, RID p_dest_color, Size2i p_source_size, Size2i p_dest_size, float p_exposure, float p_white, float p_luminance_multiplier) {
+	// GRX Route B rd_native tonemap: an in-frame RD-native compute replacement.
+	// This does NOT go through the Rurix rxgd bridge/shim (session/record_pass);
+	// it drives the main RenderingDevice directly so the Rurix tonemap kernel
+	// runs as a first-class pass inside the frame graph. Every early return below
+	// keeps the native Godot tonemapper (fail-closed). The caller only reaches
+	// here when the backend selector is 2 (rd_native).
+	RenderingDevice *rd = RenderingDevice::get_singleton();
+	if (rd == nullptr) {
+		return false;
+	}
+	if (rd_native_tonemap_load_failed) {
+		// A prior container load / pipeline compile failed; do not retry every
+		// frame (and do not spam diagnostics). The native tonemap path renders.
+		return false;
+	}
+	if (!p_source_color.is_valid() || !p_dest_color.is_valid()) {
+		return false;
+	}
+	if (p_dest_size.x <= 0 || p_dest_size.y <= 0) {
+		return false;
+	}
+	// Usage-bits preflight: the source must be sampleable (SRV t0) and the
+	// destination must be storage-writable (UAV u0). Both tonemap destination
+	// legs already carry STORAGE_BIT today; this preflight guards against a
+	// future Godot snapshot changing those flags, and fails closed rather than
+	// letting uniform_set_create assert mid-frame.
+	const RenderingDevice::TextureFormat src_format = rd->texture_get_format(p_source_color);
+	const RenderingDevice::TextureFormat dst_format = rd->texture_get_format(p_dest_color);
+	if ((src_format.usage_bits & RenderingDevice::TEXTURE_USAGE_SAMPLING_BIT) == 0) {
+		return false;
+	}
+	if ((dst_format.usage_bits & RenderingDevice::TEXTURE_USAGE_STORAGE_BIT) == 0) {
+		return false;
+	}
+	// Lazily build the compute pipeline the first time backend == 2 is
+	// exercised: read the Rurix container bytes, hand them to
+	// shader_create_from_bytecode (-> shader_create_from_container in the D3D12
+	// driver; the driver consumes the container's DXIL + RTS0 verbatim), and
+	// create the compute pipeline (-> CreateRootSignature + PSO). Any failure
+	// latches rd_native_tonemap_load_failed so it is not retried per frame.
+	if (!rd_native_tonemap_shader.is_valid() || !rd_native_tonemap_pipeline.is_valid()) {
+		const String container_path = GLOBAL_GET("rendering/rurix_accel/passes/tonemap/rd_container_path");
+		if (container_path.is_empty()) {
+			// No container configured: keep rd_native fail-closed (disabled).
+			rd_native_tonemap_load_failed = true;
+			return false;
+		}
+		const Vector<uint8_t> container_bytes = FileAccess::get_file_as_bytes(container_path);
+		if (container_bytes.is_empty()) {
+			rd_native_tonemap_load_failed = true;
+			print_verbose(vformat("RurixAccel: rd_native tonemap container '%s' missing or empty; native tonemap path remains active.", container_path));
+			return false;
+		}
+		const RID shader = rd->shader_create_from_bytecode(container_bytes);
+		if (!shader.is_valid()) {
+			rd_native_tonemap_load_failed = true;
+			print_verbose("RurixAccel: rd_native tonemap shader_create_from_bytecode failed; native tonemap path remains active.");
+			return false;
+		}
+		const RID pipeline = rd->compute_pipeline_create(shader);
+		if (!pipeline.is_valid()) {
+			rd->free_rid(shader);
+			rd_native_tonemap_load_failed = true;
+			print_verbose("RurixAccel: rd_native tonemap compute_pipeline_create failed; native tonemap path remains active.");
+			return false;
+		}
+		rd_native_tonemap_shader = shader;
+		rd_native_tonemap_pipeline = pipeline;
+		if (!rd_native_tonemap_active_logged) {
+			// One-shot marker (NOT per-frame): the RD-native tonemap replacement
+			// is engaged and the native Godot tonemapper is being skipped.
+			print_verbose("RXGD_RD_NATIVE_TONEMAP active: backend=rd_native, in-frame compute replacement engaged (native Godot tonemapper skipped).");
+			rd_native_tonemap_active_logged = true;
+		}
+	}
+	// Bind t0 = source color (SRV, UNIFORM_TYPE_TEXTURE) and u0 = destination
+	// (UAV, UNIFORM_TYPE_IMAGE). UniformSetCacheRD keys on the RID set and
+	// auto-invalidates the cached set when either texture is freed (resize), so
+	// no manual lifetime handling is needed.
+	const RID uniform_set = UniformSetCacheRD::get_singleton()->get_cache(
+			rd_native_tonemap_shader, 0,
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_TEXTURE, 0, p_source_color),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_IMAGE, 1, p_dest_color));
+	if (!uniform_set.is_valid()) {
+		return false;
+	}
+	// b0 root constants (28 bytes / 7 DWORDs): source_width and source_height as
+	// 64-bit integers (the tonemap kernel declares the 64-bit integer shader
+	// capability), then exposure, white and luminance_multiplier as 32-bit
+	// floats, little-endian like D3D12. This mirrors the shim path's tonemap
+	// packing (patch 0012) and the S2 probe's validated layout.
+	uint8_t push_constants[TONEMAP_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES] = {};
+	const uint64_t source_width = (uint64_t)MAX(p_source_size.x, 0);
+	const uint64_t source_height = (uint64_t)MAX(p_source_size.y, 0);
+	memcpy(&push_constants[0], &source_width, sizeof(source_width));
+	memcpy(&push_constants[8], &source_height, sizeof(source_height));
+	memcpy(&push_constants[16], &p_exposure, sizeof(p_exposure));
+	memcpy(&push_constants[20], &p_white, sizeof(p_white));
+	memcpy(&push_constants[24], &p_luminance_multiplier, sizeof(p_luminance_multiplier));
+	// Record the in-frame compute dispatch. This runs inside
+	// _render_buffers_post_process_and_tonemap between the native sub-passes;
+	// the main-RD draw graph tracks the uniform_set_create resources as
+	// first-class citizens and inserts the required barriers automatically (no
+	// manual barrier, and no submit()/sync() — that is a local-RD-only concept).
+	const RenderingDevice::ComputeListID compute_list = rd->compute_list_begin();
+	rd->compute_list_bind_compute_pipeline(compute_list, rd_native_tonemap_pipeline);
+	rd->compute_list_bind_uniform_set(compute_list, uniform_set, 0);
+	rd->compute_list_set_push_constant(compute_list, push_constants, TONEMAP_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES);
+	const uint32_t groups_x = (uint32_t)((MAX(p_dest_size.x, 0) + 7) / 8);
+	const uint32_t groups_y = (uint32_t)((MAX(p_dest_size.y, 0) + 7) / 8);
+	rd->compute_list_dispatch(compute_list, groups_x, groups_y, 1);
+	rd->compute_list_end();
+	return true;
+}
+
 #endif // D3D12_ENABLED
