 	RID rd_native_ssao_blur_pipeline;
 	bool rd_native_ssao_blur_load_failed = false;
 	bool rd_native_ssao_blur_active_logged = false;
+	// GRX Route B rd_native taa_resolve: lazily-built RD compute pipeline for the
+	// in-frame TAA resolve replacement. Same lifetime discipline as the tonemap
+	// and ssao_blur members above: the shader/pipeline are created once from the
+	// Rurix container the first time backend == 2 is exercised and cached for the
