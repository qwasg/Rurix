 modules/rurix_accel/register_types.cpp        |  18 +++
 modules/rurix_accel/rurix_accel.cpp           | 133 ++++++++++++++++++
 modules/rurix_accel/rurix_accel.h             |  28 ++++
 servers/rendering/renderer_rd/effects/taa.cpp |  33 ++++-
 5 files changed, 229 insertions(+), 1 deletion(-)

diff --git a/drivers/d3d12/d3d12_hooks.h b/drivers/d3d12/d3d12_hooks.h
index 0feab9b..b6a53cb 100644
--- a/drivers/d3d12/d3d12_hooks.h
+++ b/drivers/d3d12/d3d12_hooks.h
@@ -175,5 +175,23 @@ public:
 	// hooks that do not override this (or the absence of a hooks singleton) keep
 	// the native Godot SSAO blur path.
 	virtual bool try_record_ssao_blur_rd_native(int64_t p_compute_list, RID p_source_slice, RID p_dest_slice, Size2i p_slice_size, float p_edge_sharpness, float p_half_screen_pixel_size_x, float p_half_screen_pixel_size_y) { return false; }
+	// GRX Route B rd_native taa_resolve: opt-in in-frame RD-native compute
+	// replacement hook for the TAA resolve compute dispatch. Unlike the shim-path
+	// try_record_taa_resolve() above (which takes native ID3D12Resource* handles
+	// for an out-of-frame bridge dispatch), this hook takes the six Godot RID
+	// handles for the resolve inputs/output in the container's binding order
+	// (color/depth/velocity/prev_velocity/history = SRV t0..t4, output temp =
+	// UAV u0) plus the shared internal resolution and the resolve b0 scalars, so
+	// the module can build an RD compute pipeline from a Rurix shader container
+	// and dispatch it as a first-class in-frame pass. It replaces ONLY the resolve
+	// compute dispatch: the caller keeps running the native history-maintenance
+	// copies (temp->internal, internal->history, velocity->prev_velocity) so the
+	// TAA feedback loop is preserved. rd_native opens/closes its own compute list
+	// (resolve() is a standalone list, unlike the shared SSAO list). Returning
+	// true means the module recorded the real resolve replacement and the native
+	// TAA resolve dispatch MUST be skipped (a real replacement, not a scaffold).
+	// The base implementation returns false so any hooks that do not override this
+	// (or the absence of a hooks singleton) keep the native Godot TAA resolve.
+	virtual bool try_record_taa_resolve_rd_native(RID p_color, RID p_depth, RID p_velocity, RID p_prev_velocity, RID p_history, RID p_output_temp, Size2i p_internal_size, float p_disocclusion_threshold, float p_variance_dynamic) { return false; }
 	static D3D12Hooks *get_singleton() { return singleton; }
 };
