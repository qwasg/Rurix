+	GLOBAL_DEF_BASIC("rendering/rurix_accel/passes/taa_resolve/rd_container_path", "");
 
 #if defined(D3D12_ENABLED)
 	if (GLOBAL_GET("rendering/rurix_accel/enabled")) {
diff --git a/modules/rurix_accel/rurix_accel.cpp b/modules/rurix_accel/rurix_accel.cpp
index f2a80c5..a7c5b43 100644
--- a/modules/rurix_accel/rurix_accel.cpp
+++ b/modules/rurix_accel/rurix_accel.cpp
@@ -1271,4 +1271,137 @@ bool RurixAccelD3D12Hooks::try_record_ssao_blur_rd_native(int64_t p_compute_list
 	return true;
 }
 
+bool RurixAccelD3D12Hooks::try_record_taa_resolve_rd_native(RID p_color, RID p_depth, RID p_velocity, RID p_prev_velocity, RID p_history, RID p_output_temp, Size2i p_internal_size, float p_disocclusion_threshold, float p_variance_dynamic) {
+	// GRX Route B rd_native taa_resolve: an in-frame RD-native compute replacement
+	// for the TAA resolve dispatch. Like the tonemap/ssao_blur rd_native paths this
+	// does NOT go through the Rurix rxgd bridge/shim (session/record_pass); it
+	// drives the main RenderingDevice directly so the Rurix taa_resolve kernel runs
+	// as a first-class dispatch inside the frame graph. It replaces ONLY the
+	// resolve dispatch (temp = f(color, depth, velocity, prev_velocity, history));
+	// the caller keeps the native history-maintenance copies (temp->internal,
+	// internal->history, velocity->prev_velocity), so the TAA feedback loop is
+	// preserved. resolve() is a standalone compute list (unlike the shared SSAO
+	// list), so this opens/closes its own list. Every early return below keeps the
+	// native Godot TAA resolve path (fail-closed). The caller only reaches here
+	// when the backend selector is 2 (rd_native).
+	RenderingDevice *rd = RenderingDevice::get_singleton();
+	if (rd == nullptr) {
+		return false;
+	}
+	if (rd_native_taa_resolve_load_failed) {
+		// A prior container load / pipeline compile failed; do not retry every
+		// frame (and do not spam diagnostics). The native TAA resolve path renders.
+		return false;
+	}
+	if (!p_color.is_valid() || !p_depth.is_valid() || !p_velocity.is_valid() || !p_prev_velocity.is_valid() || !p_history.is_valid() || !p_output_temp.is_valid()) {
+		return false;
+	}
+	if (p_internal_size.x <= 0 || p_internal_size.y <= 0) {
+		return false;
+	}
+	// Usage-bits preflight: the five resolve inputs must be sampleable (SRV
+	// t0..t4) and the temp output must be storage-writable (UAV u0). The taa
+	// history/temp/prev_velocity textures are created with SAMPLING_BIT |
+	// STORAGE_BIT, and the internal/depth/velocity textures carry SAMPLING_BIT;
+	// this preflight guards against a future Godot snapshot changing those flags
+	// and fails closed rather than letting uniform_set_create assert mid-frame.
+	const RID srv_inputs[5] = { p_color, p_depth, p_velocity, p_prev_velocity, p_history };
+	for (uint32_t i = 0; i < 5; i++) {
+		const RenderingDevice::TextureFormat fmt = rd->texture_get_format(srv_inputs[i]);
+		if ((fmt.usage_bits & RenderingDevice::TEXTURE_USAGE_SAMPLING_BIT) == 0) {
+			return false;
+		}
+	}
+	const RenderingDevice::TextureFormat out_format = rd->texture_get_format(p_output_temp);
+	if ((out_format.usage_bits & RenderingDevice::TEXTURE_USAGE_STORAGE_BIT) == 0) {
+		return false;
+	}
+	// Lazily build the compute pipeline the first time backend == 2 is exercised:
+	// read the Rurix container bytes, hand them to shader_create_from_bytecode
+	// (-> shader_create_from_container in the D3D12 driver; the driver consumes the
+	// container's DXIL + RTS0 verbatim), and create the compute pipeline
+	// (-> CreateRootSignature + PSO). Any failure latches
+	// rd_native_taa_resolve_load_failed so it is not retried per frame.
+	if (!rd_native_taa_resolve_shader.is_valid() || !rd_native_taa_resolve_pipeline.is_valid()) {
+		const String container_path = GLOBAL_GET("rendering/rurix_accel/passes/taa_resolve/rd_container_path");
+		if (container_path.is_empty()) {
+			// No container configured: keep rd_native fail-closed (disabled).
+			rd_native_taa_resolve_load_failed = true;
+			return false;
+		}
+		const Vector<uint8_t> container_bytes = FileAccess::get_file_as_bytes(container_path);
+		if (container_bytes.is_empty()) {
+			rd_native_taa_resolve_load_failed = true;
+			print_verbose(vformat("RurixAccel: rd_native taa_resolve container '%s' missing or empty; native TAA resolve path remains active.", container_path));
+			return false;
+		}
+		const RID shader = rd->shader_create_from_bytecode(container_bytes);
+		if (!shader.is_valid()) {
+			rd_native_taa_resolve_load_failed = true;
+			print_verbose("RurixAccel: rd_native taa_resolve shader_create_from_bytecode failed; native TAA resolve path remains active.");
+			return false;
+		}
+		const RID pipeline = rd->compute_pipeline_create(shader);
+		if (!pipeline.is_valid()) {
+			rd->free_rid(shader);
+			rd_native_taa_resolve_load_failed = true;
+			print_verbose("RurixAccel: rd_native taa_resolve compute_pipeline_create failed; native TAA resolve path remains active.");
+			return false;
+		}
+		rd_native_taa_resolve_shader = shader;
+		rd_native_taa_resolve_pipeline = pipeline;
+		if (!rd_native_taa_resolve_active_logged) {
+			// One-shot marker (NOT per-frame): the RD-native TAA resolve
+			// replacement is engaged and the native Godot resolve dispatch is being
+			// skipped (the native history-maintenance copies still run).
+			print_verbose("RXGD_RD_NATIVE_TAA_RESOLVE active: backend=rd_native, in-frame resolve dispatch replacement engaged (native Godot resolve dispatch skipped; native history copies preserved).");
+			rd_native_taa_resolve_active_logged = true;
+		}
+	}
+	// Bind the six resolve resources in the container's binding order: t0=color,
+	// t1=depth, t2=velocity, t3=prev_velocity, t4=history (SRV,
+	// UNIFORM_TYPE_TEXTURE), u0=temp output (UAV, UNIFORM_TYPE_IMAGE, binding 5).
+	// UniformSetCacheRD keys on the RID set and auto-invalidates the cached set
+	// when any texture is freed (resize), so no manual lifetime handling is needed.
+	const RID uniform_set = UniformSetCacheRD::get_singleton()->get_cache(
+			rd_native_taa_resolve_shader, 0,
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_TEXTURE, 0, p_color),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_TEXTURE, 1, p_depth),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_TEXTURE, 2, p_velocity),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_TEXTURE, 3, p_prev_velocity),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_TEXTURE, 4, p_history),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_IMAGE, 5, p_output_temp));
+	if (!uniform_set.is_valid()) {
+		return false;
+	}
+	// b0 root constants (28 bytes / 7 DWORDs): resolution_width and
+	// resolution_height as 64-bit integers (the taa_resolve kernel declares the
+	// 64-bit integer shader capability), then disocclusion_threshold,
+	// variance_dynamic and a reserved0 float, little-endian like D3D12. This
+	// mirrors the shim path's taa_resolve packing (patch 0018) and the container's
+	// declared 28-byte push_constant_size.
+	uint8_t push_constants[TAA_RESOLVE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES] = {};
+	const uint64_t resolution_width = (uint64_t)MAX(p_internal_size.x, 0);
+	const uint64_t resolution_height = (uint64_t)MAX(p_internal_size.y, 0);
+	const float reserved0 = 0.0f;
+	memcpy(&push_constants[0], &resolution_width, sizeof(resolution_width));
+	memcpy(&push_constants[8], &resolution_height, sizeof(resolution_height));
+	memcpy(&push_constants[16], &p_disocclusion_threshold, sizeof(p_disocclusion_threshold));
+	memcpy(&push_constants[20], &p_variance_dynamic, sizeof(p_variance_dynamic));
+	memcpy(&push_constants[24], &reserved0, sizeof(reserved0));
+	// Record the in-frame resolve compute dispatch. resolve() is a standalone
+	// compute list, so this opens and closes its own list (no submit()/sync() —
+	// that is a local-RD-only concept); the main-RD draw graph tracks the
+	// uniform_set_create resources and inserts the required barriers automatically.
+	const RenderingDevice::ComputeListID compute_list = rd->compute_list_begin();
+	rd->compute_list_bind_compute_pipeline(compute_list, rd_native_taa_resolve_pipeline);
+	rd->compute_list_bind_uniform_set(compute_list, uniform_set, 0);
+	rd->compute_list_set_push_constant(compute_list, push_constants, TAA_RESOLVE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES);
+	const uint32_t groups_x = (uint32_t)((MAX(p_internal_size.x, 0) + 7) / 8);
+	const uint32_t groups_y = (uint32_t)((MAX(p_internal_size.y, 0) + 7) / 8);
+	rd->compute_list_dispatch(compute_list, groups_x, groups_y, 1);
+	rd->compute_list_end();
+	return true;
+}
+
 #endif // D3D12_ENABLED
