+	RID rd_native_taa_resolve_shader;
+	RID rd_native_taa_resolve_pipeline;
+	bool rd_native_taa_resolve_load_failed = false;
+	bool rd_native_taa_resolve_active_logged = false;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES = 28;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_RESOURCE_COUNT = 2;
 	// GRX-010 tonemap resource mapping (resource_mapping.md): b0 carries
@@ -350,6 +363,21 @@ public:
 	// returns false and the caller keeps the native Godot SSAO blur path
 	// (fail-closed).
 	bool try_record_ssao_blur_rd_native(int64_t p_compute_list, RID p_source_slice, RID p_dest_slice, Size2i p_slice_size, float p_edge_sharpness, float p_half_screen_pixel_size_x, float p_half_screen_pixel_size_y) override;
+	// GRX Route B rd_native taa_resolve: in-frame RD-native compute replacement
+	// for the TAA resolve dispatch. Lazily builds the RD compute pipeline from the
+	// Rurix container named by rendering/rurix_accel/passes/taa_resolve/rd_container_path,
+	// binds the six resolve textures (color/depth/velocity/prev_velocity/history =
+	// SRV t0..t4, output temp = UAV u0) plus the 28-byte b0 push constants, and
+	// dispatches ceil(size/8) compute groups on the main RenderingDevice's active
+	// frame (its own compute_list_begin/end, since resolve() is a standalone
+	// list). It replaces ONLY the resolve dispatch; the caller keeps the native
+	// history-maintenance copies. Returns true only when the resolve was actually
+	// recorded (real replacement — the caller then SKIPS the native resolve). Any
+	// failure (RD unavailable, latched load failure, invalid RID, missing usage
+	// bits, empty/invalid container, pipeline or uniform-set creation failure)
+	// returns false and the caller keeps the native Godot TAA resolve path
+	// (fail-closed).
+	bool try_record_taa_resolve_rd_native(RID p_color, RID p_depth, RID p_velocity, RID p_prev_velocity, RID p_history, RID p_output_temp, Size2i p_internal_size, float p_disocclusion_threshold, float p_variance_dynamic) override;
 };
 
 #endif // D3D12_ENABLED
