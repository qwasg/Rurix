+			if (D3D12Hooks::get_singleton() != nullptr && ((int)GLOBAL_GET("rendering/rurix_accel/passes/taa_resolve/backend")) == 2) {
+				const float rurix_taa_disocclusion = 2.5f;
+				const float rurix_taa_variance = CLAMP(1.1f * (1080.0f / (float)MAX(internal_size.y, 1)), 0.75f, 1.0f);
+				rurix_recorded_taa_resolve_rd_native = D3D12Hooks::get_singleton()->try_record_taa_resolve_rd_native(internal_texture, depth_texture, velocity_buffer, taa_prev_velocity, taa_history, taa_temp, Size2i(internal_size.x, internal_size.y), rurix_taa_disocclusion, rurix_taa_variance);
