+
+env_rurix_accel.add_source_files(env.modules_sources, "register_types.cpp")
+env_rurix_accel.add_source_files(env.modules_sources, "rurix_accel.cpp")
diff --git a/modules/rurix_accel/config.py b/modules/rurix_accel/config.py
new file mode 100644
index 0000000000..2222222222
--- /dev/null
+++ b/modules/rurix_accel/config.py
@@ -0,0 +1,14 @@
+def can_build(env, platform):
+    return platform == "windows"
+
+
+def get_opts(platform):
+    from SCons.Variables import BoolVariable
+
+    return [
+        BoolVariable("module_rurix_accel_enabled", "Enable opt-in Rurix D3D12 Forward+ acceleration bridge", False),
+    ]
+
+
+def configure(env):
+    pass
diff --git a/modules/rurix_accel/register_types.cpp b/modules/rurix_accel/register_types.cpp
new file mode 100644
index 0000000000..3333333333
--- /dev/null
+++ b/modules/rurix_accel/register_types.cpp
@@ -0,0 +1,38 @@
+#include "register_types.h"
+
+#include "rurix_accel.h"
+
+#include "core/config/project_settings.h"
+
+static RurixAccelD3D12Hooks *rurix_accel_hooks = nullptr;
+
+void initialize_rurix_accel_module(ModuleInitializationLevel p_level) {
+	if (p_level != MODULE_INITIALIZATION_LEVEL_SERVERS) {
+		return;
+	}
+
+	GLOBAL_DEF_BASIC("rendering/rurix_accel/enabled", false);
+	GLOBAL_DEF_BASIC("rendering/rurix_accel/require_forward_plus", true);
+	GLOBAL_DEF_BASIC("rendering/rurix_accel/dll_path", "rurix_godot.dll");
+
+#if defined(D3D12_ENABLED)
+	if (GLOBAL_GET("rendering/rurix_accel/enabled")) {
+		if (RurixAccelD3D12Hooks::bridge_preflight()) {
+			rurix_accel_hooks = memnew(RurixAccelD3D12Hooks);
+		}
+	}
+#endif
+}
+
+void uninitialize_rurix_accel_module(ModuleInitializationLevel p_level) {
+	if (p_level != MODULE_INITIALIZATION_LEVEL_SERVERS) {
+		return;
+	}
+
+#if defined(D3D12_ENABLED)
+	if (rurix_accel_hooks != nullptr) {
+		memdelete(rurix_accel_hooks);
+		rurix_accel_hooks = nullptr;
+	}
+#endif
+}
