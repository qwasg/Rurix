+				// binding numbers 1/3/2 are a different order). When
+				// RenderingDevice is unavailable, a buffer RID is null, or a
+				// handle resolves to 0 the pass falls back to the native cluster
+				// store dispatch. Returns true only when the Rurix module setting
+				// is enabled AND the bridge session/symbol exist AND
 				// rxgd_record_pass returns RXGD_STATUS_OK. The fail-closed bridge
-				// ClusterStoreGate always returns RXGD_STATUS_FALLBACK for
-				// RXGD_PASS_CLUSTER_STORE today, so this stays false and the
-				// native cluster store dispatch below runs.
-				rurix_recorded_cluster_store = D3D12Hooks::get_singleton()->try_record_cluster_store();
+				// ClusterStoreGate still always returns RXGD_STATUS_FALLBACK for
+				// RXGD_PASS_CLUSTER_STORE on the default path, so this stays false
+				// and the native dispatch runs.
+				RenderingDevice *rurix_cluster_rd = RD::get_singleton();
+				const uint64_t rurix_cluster_render_handle = (rurix_cluster_rd != nullptr && cluster_render_buffer.is_valid()) ? rurix_cluster_rd->get_driver_resource(RenderingDevice::DRIVER_RESOURCE_BUFFER, cluster_render_buffer, 0) : 0;
+				const uint64_t rurix_render_elements_handle = (rurix_cluster_rd != nullptr && element_buffer.is_valid()) ? rurix_cluster_rd->get_driver_resource(RenderingDevice::DRIVER_RESOURCE_BUFFER, element_buffer, 0) : 0;
+				const uint64_t rurix_cluster_store_handle = (rurix_cluster_rd != nullptr && cluster_buffer.is_valid()) ? rurix_cluster_rd->get_driver_resource(RenderingDevice::DRIVER_RESOURCE_BUFFER, cluster_buffer, 0) : 0;
+				if (rurix_cluster_render_handle != 0 && rurix_render_elements_handle != 0 && rurix_cluster_store_handle != 0) {
