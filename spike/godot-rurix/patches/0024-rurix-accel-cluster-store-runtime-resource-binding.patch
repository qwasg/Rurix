@@ -538,16 +538,38 @@ void ClusterBuilderRD::bake_cluster() {
 			bool rurix_recorded_cluster_store = false;
 #ifdef D3D12_ENABLED
 			if (D3D12Hooks::get_singleton() != nullptr) {
-				// GRX-014 opt-in gate. Only the compute merge (store) segment is
-				// in scope: the preceding cluster_render raster segment, the
-				// buffer clears, and the render_element_count == 0 early-out stay
-				// native permanently. Returns true only when the Rurix module
-				// setting is enabled AND the bridge session/symbol exist AND
+				// GRX-014 runtime resource binding gate (0005/0007-level in one
+				// slice). Only the compute merge (store) segment is in scope: the
+				// preceding cluster_render raster segment, the buffer clears, and
+				// the render_element_count == 0 early-out stay native permanently.
+				// Resolve the real D3D12 ID3D12Resource* native handles (not
+				// logical Godot RID ids) for the three structured buffers through
+				// RenderingDevice::get_driver_resource (DRIVER_RESOURCE_BUFFER),
