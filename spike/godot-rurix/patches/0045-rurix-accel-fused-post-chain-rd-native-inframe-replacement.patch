@@ -375,6 +375,25 @@ void initialize_rurix_accel_module(ModuleInitializationLevel p_level) {
 	// a res:// resource so the smoke/bench harnesses can point at an absolute
 	// staging path.
 	GLOBAL_DEF_BASIC("rendering/rurix_accel/passes/cluster_store/rd_container_path", "");
+	// GRX Route B rd_native fused_post_chain: three-state backend selector for the
+	// fused luminance-final + tonemap pass. Bridge-independent and self-contained on
+	// the culling tail (the fused shim scaffold 0036-0038 lives on the
+	// mutually-exclusive fused tail and is NOT in this stack). Values:
+	// 0 = disabled (default; the tonemap rd_native / shim / native chain is
+	// unchanged), 1 = reserved (nominal; no shim path exists on this tail so 1
+	// behaves as disabled here), 2 = rd_native (engage the in-frame RD-native fused
+	// replacement via try_record_fused_post_chain_rd_native, which is the
+	// fusion-first leg cascading into the patch 0040 tonemap rd_native single-pass
+	// fallback). Defaults to 0 so the shipping build/config never engages it.
+	GLOBAL_DEF_BASIC("rendering/rurix_accel/passes/fused_post_chain/backend", 0);
+	// GRX Route B rd_native fused_post_chain: absolute filesystem path to the Rurix
+	// RenderingShaderContainerD3D12 fused_post_chain container consumed by
+	// shader_create_from_bytecode when backend == 2. Defaults to empty, which keeps
+	// the RD-native path fail-closed (no container -> tonemap rd_native / native
+	// chain remains active). The container path is injected here rather than
+	// hardcoded to a res:// resource so the smoke/bench harnesses can point at an
+	// absolute staging path.
