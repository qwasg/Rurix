 modules/rurix_accel/register_types.cpp        |  19 +++
 modules/rurix_accel/rurix_accel.cpp           | 155 ++++++++++++++++++
 modules/rurix_accel/rurix_accel.h             |  40 +++++
 .../renderer_rd/renderer_scene_render_rd.cpp  |  36 +++-
 5 files changed, 268 insertions(+), 3 deletions(-)

diff --git a/drivers/d3d12/d3d12_hooks.h b/drivers/d3d12/d3d12_hooks.h
index fa65fc8..0bddfe0 100644
--- a/drivers/d3d12/d3d12_hooks.h
+++ b/drivers/d3d12/d3d12_hooks.h
@@ -231,5 +231,26 @@ public:
 	// override this (or the absence of a hooks singleton) keep the native Godot
 	// cluster store path.
 	virtual bool try_record_cluster_store_rd_native(int64_t p_compute_list, RID p_cluster_render, RID p_render_elements, RID p_cluster_store, Size2i p_screen_size, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes) { return false; }
+	// GRX Route B rd_native fused_post_chain: opt-in in-frame RD-native compute
+	// replacement hook for the fused luminance-final + tonemap pass. Unlike the
+	// shim-path try_record_fused_post_chain() (which lives on the mutually-exclusive
+	// fused tail and takes native ID3D12Resource* handles), this hook takes the five
+	// Godot texture RID handles in the container's binding order (src_color = SRV
+	// t0, lum_source = SRV t1, prev_luminance = SRV t2, dst_color = UAV u0,
+	// dst_luminance = UAV u1) plus the source/dest sizes and the tonemap b0 scalars,
+	// so the module can build an RD compute pipeline from a Rurix shader container
+	// and dispatch it as a first-class in-frame pass (its own compute list, like the
+	// tonemap rd_native path). It is the FUSION-FIRST leg of the two-level fallback
+	// (fused rd_native -> single-pass tonemap rd_native -> native). The distinct
+	// double-buffered luminance-final targets are NOT exposed by the public
+	// Luminance API at the tonemap call site, so the module fails closed when the
+	// lum_source/prev_luminance or dst_color/dst_luminance RIDs alias (the deferred
+	// Luminance-API extension is the prerequisite), and only records a genuine
+	// replacement when distinct valid luminance targets are supplied. Returning true
+	// means the module recorded the real replacement and the native Godot
+	// luminance-final + tonemap end MUST be skipped. The base implementation returns
+	// false so any hooks that do not override this (or the absence of a hooks
+	// singleton) keep the native Godot luminance_reduction + tonemap chain.
+	virtual bool try_record_fused_post_chain_rd_native(RID p_src_color, RID p_lum_source, RID p_prev_luminance, RID p_dst_color, RID p_dst_luminance, Size2i p_source_size, Size2i p_dest_size, float p_exposure, float p_white, float p_luminance_multiplier) { return false; }
 	static D3D12Hooks *get_singleton() { return singleton; }
 };
diff --git a/modules/rurix_accel/register_types.cpp b/modules/rurix_accel/register_types.cpp
