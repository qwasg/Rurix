diff --git a/modules/rurix_accel/rurix_accel.cpp b/modules/rurix_accel/rurix_accel.cpp
index e1d1679..f5ef657 100644
--- a/modules/rurix_accel/rurix_accel.cpp
+++ b/modules/rurix_accel/rurix_accel.cpp
@@ -1618,4 +1618,187 @@ bool RurixAccelD3D12Hooks::try_record_cluster_store_rd_native(int64_t p_compute_
 	return true;
 }
 
+bool RurixAccelD3D12Hooks::try_record_fused_post_chain_rd_native(RID p_src_color, RID p_lum_source, RID p_prev_luminance, RID p_dst_color, RID p_dst_luminance, Size2i p_source_size, Size2i p_dest_size, float p_exposure, float p_white, float p_luminance_multiplier, float p_min_luminance, float p_max_luminance, float p_exposure_adjust, float p_first_frame, float p_auto_exposure_scale) {
+	// GRX Route B rd_native fused_post_chain: an in-frame RD-native compute
+	// replacement for the fused luminance-final + tonemap pass. Like the other
+	// rd_native paths this does NOT go through the Rurix rxgd bridge/shim; it drives
+	// the main RenderingDevice directly. It is the FUSION-FIRST leg of the two-level
+	// fallback (fused rd_native -> single-pass tonemap rd_native (patch 0040) ->
+	// native). fused_post_chain is a standalone compute list (the tonemap block has
+	// no active list), so this opens/closes its own list. Every early return below
+	// keeps the tonemap rd_native / native chain (fail-closed). The caller only
+	// reaches here when the fused backend selector is 2 (rd_native).
+	RenderingDevice *rd = RenderingDevice::get_singleton();
+	if (rd == nullptr) {
+		return false;
+	}
+	if (rd_native_fused_post_chain_load_failed) {
+		// A prior container load / pipeline compile failed; do not retry every
+		// frame (and do not spam diagnostics). The tonemap/native chain renders.
+		return false;
+	}
+	if (!p_src_color.is_valid() || !p_lum_source.is_valid() || !p_prev_luminance.is_valid() || !p_dst_color.is_valid() || !p_dst_luminance.is_valid()) {
+		return false;
+	}
+	// Distinct-luminance guard (patch 0045 in-place revision — Design 1 fused
+	// shadow-recompute unlocked by the patch 0048 Luminance-API getters). The call
+	// site now supplies DISTINCT current / previous / penultimate luminance buffers
+	// (get_current_luminance_buffer / get_previous_luminance_buffer /
+	// get_luminance_reduce_penultimate_buffer): lum_source = current (this frame's
+	// final), prev_luminance = previous (last frame's final = reduce[size-1] after
+	// SWAP). If they still alias (no auto-exposure this frame, so the Luminance
+	// custom-data / distinct final buffers do not exist), the fused luminance leg
+	// would be degenerate — fail closed so the caller cascades to the patch 0040
+	// tonemap rd_native single-pass fallback. NOTE the p_dst_luminance argument is
+	// used ONLY to keep a valid, distinct handle in the signature (the call site
+	// passes the penultimate reduce level); the fused kernel's dst_luminance WRITE
+	// is redirected below to a self-owned scratch, so no real luminance buffer is
+	// ever written (honest shadow-recompute; the native luminance_reduction still
+	// runs in full, no dispatch saving claimed).
+	if (p_lum_source == p_prev_luminance) {
+		return false;
+	}
+	if (p_dest_size.x <= 0 || p_dest_size.y <= 0) {
+		return false;
+	}
+	// Usage-bits preflight: the three SRV inputs must be sampleable and the LDR
+	// destination (u0) must be storage-writable. Fails closed rather than letting
+	// uniform_set_create assert mid-frame. The dst_luminance UAV (u1) is a
+	// self-owned scratch created with STORAGE_BIT below, so it needs no preflight
+	// on p_dst_luminance (which is never bound / written).
+	const RID srv_inputs[3] = { p_src_color, p_lum_source, p_prev_luminance };
+	for (uint32_t i = 0; i < 3; i++) {
+		const RenderingDevice::TextureFormat fmt = rd->texture_get_format(srv_inputs[i]);
+		if ((fmt.usage_bits & RenderingDevice::TEXTURE_USAGE_SAMPLING_BIT) == 0) {
+			return false;
+		}
+	}
+	{
+		const RenderingDevice::TextureFormat fmt = rd->texture_get_format(p_dst_color);
+		if ((fmt.usage_bits & RenderingDevice::TEXTURE_USAGE_STORAGE_BIT) == 0) {
+			return false;
+		}
+	}
+	// Lazily build the compute pipeline the first time backend == 2 is exercised
+	// with distinct valid targets: read the Rurix container bytes, hand them to
+	// shader_create_from_bytecode, and create the compute pipeline. Any failure
+	// latches rd_native_fused_post_chain_load_failed so it is not retried per frame.
+	if (!rd_native_fused_post_chain_shader.is_valid() || !rd_native_fused_post_chain_pipeline.is_valid()) {
+		const String container_path = GLOBAL_GET("rendering/rurix_accel/passes/fused_post_chain/rd_container_path");
+		if (container_path.is_empty()) {
+			// No container configured: keep rd_native fail-closed (disabled).
+			rd_native_fused_post_chain_load_failed = true;
+			return false;
+		}
+		const Vector<uint8_t> container_bytes = FileAccess::get_file_as_bytes(container_path);
+		if (container_bytes.is_empty()) {
+			rd_native_fused_post_chain_load_failed = true;
+			print_verbose(vformat("RurixAccel: rd_native fused_post_chain container '%s' missing or empty; tonemap/native chain remains active.", container_path));
+			return false;
+		}
+		const RID shader = rd->shader_create_from_bytecode(container_bytes);
+		if (!shader.is_valid()) {
+			rd_native_fused_post_chain_load_failed = true;
+			print_verbose("RurixAccel: rd_native fused_post_chain shader_create_from_bytecode failed; tonemap/native chain remains active.");
+			return false;
+		}
+		const RID pipeline = rd->compute_pipeline_create(shader);
+		if (!pipeline.is_valid()) {
+			rd->free_rid(shader);
+			rd_native_fused_post_chain_load_failed = true;
+			print_verbose("RurixAccel: rd_native fused_post_chain compute_pipeline_create failed; tonemap/native chain remains active.");
+			return false;
+		}
+		rd_native_fused_post_chain_shader = shader;
+		rd_native_fused_post_chain_pipeline = pipeline;
+		if (!rd_native_fused_post_chain_active_logged) {
+			// One-shot marker (NOT per-frame): the RD-native fused replacement is
+			// engaged and the native Godot luminance-final + tonemap end is skipped.
+			print_verbose("RXGD_RD_NATIVE_FUSED_POST_CHAIN active: backend=rd_native, in-frame fused luminance-final + tonemap replacement engaged (native Godot luminance-final + tonemap end skipped).");
+			rd_native_fused_post_chain_active_logged = true;
+		}
+	}
+	// Lazily create the self-owned 1x1 R32_SFLOAT STORAGE scratch bound to the
+	// fused kernel's dst_luminance UAV (u1). The fused luminance-final WRITE lands
+	// here and is NEVER read back (honest shadow-recompute): binding a real
+	// luminance buffer to u1 would corrupt the native auto-exposure feedback loop
+	// (current) or next frame's reduction source (penultimate), so the write is
+	// isolated to this scratch. A full-resolution dispatch whose threads address a
+	// 1x1 UAV simply drop their out-of-bounds writes (D3D12 UAV OOB writes are
+	// silently discarded), so the scratch size is irrelevant to correctness.
+	// Precedent: the gpu_culling rurix_gpu_culling_visibility_buffers self-built
+	// resource (patch 0028).
+	if (!rd_native_fused_post_chain_scratch_luminance.is_valid()) {
+		RenderingDevice::TextureFormat scratch_format;
+		scratch_format.format = RenderingDevice::DATA_FORMAT_R32_SFLOAT;
+		scratch_format.width = 1;
+		scratch_format.height = 1;
+		scratch_format.usage_bits = RenderingDevice::TEXTURE_USAGE_STORAGE_BIT;
+		rd_native_fused_post_chain_scratch_luminance = rd->texture_create(scratch_format, RenderingDevice::TextureView());
+		if (!rd_native_fused_post_chain_scratch_luminance.is_valid()) {
+			// Scratch allocation failed: keep the tonemap/native chain (fail-closed).
+			return false;
+		}
+	}
+	// Bind the five fused textures in the container's binding order: t0=src_color,
+	// t1=lum_source (current), t2=prev_luminance (previous) (SRV, UNIFORM_TYPE_TEXTURE),
+	// u0=dst_color, u1=scratch (UAV, UNIFORM_TYPE_IMAGE). u1 is the self-owned
+	// write-only scratch — NOT p_dst_luminance — so the shadow luminance-final write
+	// never touches a real luminance buffer. UniformSetCacheRD keys on the RID set
+	// and auto-invalidates the cached set when any texture is freed.
+	const RID uniform_set = UniformSetCacheRD::get_singleton()->get_cache(
+			rd_native_fused_post_chain_shader, 0,
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_TEXTURE, 0, p_src_color),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_TEXTURE, 1, p_lum_source),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_TEXTURE, 2, p_prev_luminance),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_IMAGE, 3, p_dst_color),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_IMAGE, 4, rd_native_fused_post_chain_scratch_luminance));
+	if (!uniform_set.is_valid()) {
+		return false;
+	}
+	// b0 root constants (64 bytes / 16 DWORDs): source_width, source_height,
+	// lum_source_width, lum_source_height as 64-bit integers (the fused kernel
+	// declares the 64-bit integer shader capability), then max_luminance,
+	// min_luminance, exposure_adjust, exposure, white, luminance_multiplier,
+	// first_frame and auto_exposure_scale as 32-bit floats, little-endian like
+	// D3D12. GRX-019 real AE parameter pipeline (patch 0045 revision #2): the five
+	// luminance-segment scalars (max/min sensitivity, adjust step, first_frame,
+	// auto_exposure_scale) are now the REAL per-frame values forwarded from the
+	// call site (mirroring the native luminance_reduction + tonemap arguments),
+	// replacing the earlier placeholder 1.0/0.0 constants that caused the measured
+	// max_abs=85/mean_abs=66 rd_native parity gap. b0 layout is UNCHANGED (dwords
+	// 8-15 already carry these fields); only the packed values change.
+	uint8_t push_constants[RD_NATIVE_FUSED_POST_CHAIN_ROOT_CONSTANT_BYTES] = {};
+	const RenderingDevice::TextureFormat lum_fmt = rd->texture_get_format(p_lum_source);
+	const uint64_t source_width = (uint64_t)MAX(p_source_size.x, 0);
+	const uint64_t source_height = (uint64_t)MAX(p_source_size.y, 0);
+	const uint64_t lum_source_width = (uint64_t)lum_fmt.width;
+	const uint64_t lum_source_height = (uint64_t)lum_fmt.height;
+	memcpy(&push_constants[0], &source_width, sizeof(source_width));
+	memcpy(&push_constants[8], &source_height, sizeof(source_height));
+	memcpy(&push_constants[16], &lum_source_width, sizeof(lum_source_width));
+	memcpy(&push_constants[24], &lum_source_height, sizeof(lum_source_height));
+	memcpy(&push_constants[32], &p_max_luminance, sizeof(p_max_luminance));
+	memcpy(&push_constants[36], &p_min_luminance, sizeof(p_min_luminance));
+	memcpy(&push_constants[40], &p_exposure_adjust, sizeof(p_exposure_adjust));
+	memcpy(&push_constants[44], &p_exposure, sizeof(p_exposure));
+	memcpy(&push_constants[48], &p_white, sizeof(p_white));
+	memcpy(&push_constants[52], &p_luminance_multiplier, sizeof(p_luminance_multiplier));
+	memcpy(&push_constants[56], &p_first_frame, sizeof(p_first_frame));
+	memcpy(&push_constants[60], &p_auto_exposure_scale, sizeof(p_auto_exposure_scale));
+	// Record the in-frame fused compute dispatch. fused_post_chain is a standalone
+	// compute list, so this opens and closes its own list (no submit()/sync() —
+	// that is a local-RD-only concept); the main-RD draw graph tracks the
+	// uniform_set_create resources and inserts the required barriers automatically.
+	const RenderingDevice::ComputeListID compute_list = rd->compute_list_begin();
+	rd->compute_list_bind_compute_pipeline(compute_list, rd_native_fused_post_chain_pipeline);
+	rd->compute_list_bind_uniform_set(compute_list, uniform_set, 0);
+	rd->compute_list_set_push_constant(compute_list, push_constants, RD_NATIVE_FUSED_POST_CHAIN_ROOT_CONSTANT_BYTES);
+	const uint32_t groups_x = (uint32_t)((MAX(p_dest_size.x, 0) + 7) / 8);
+	const uint32_t groups_y = (uint32_t)((MAX(p_dest_size.y, 0) + 7) / 8);
+	rd->compute_list_dispatch(compute_list, groups_x, groups_y, 1);
+	rd->compute_list_end();
+	return true;
+}
+
 #endif // D3D12_ENABLED
diff --git a/modules/rurix_accel/rurix_accel.h b/modules/rurix_accel/rurix_accel.h
index b14afe6..462c201 100644
--- a/modules/rurix_accel/rurix_accel.h
+++ b/modules/rurix_accel/rurix_accel.h
@@ -216,6 +216,46 @@ class RurixAccelD3D12Hooks : public D3D12Hooks {
 	RID rd_native_cluster_store_pipeline;
 	bool rd_native_cluster_store_load_failed = false;
 	bool rd_native_cluster_store_active_logged = false;
+	// GRX Route B rd_native fused_post_chain: lazily-built RD compute pipeline for
+	// the in-frame fused luminance-final + tonemap replacement. Same lifetime
+	// discipline as the members above. rd_native_fused_post_chain_load_failed
+	// latches a load/compile failure so it is not retried every frame, and
+	// rd_native_fused_post_chain_active_logged gates the one-shot
+	// RXGD_RD_NATIVE_FUSED_POST_CHAIN active marker (not per-frame). This slice is
+	// self-contained on the culling tail: it reuses no fused-shim (0036-0038) state
+	// and defines its own 64-byte b0 / 5-resource contract below rather than the
+	// fused-tail FUSED_POST_CHAIN_RESOURCE_MAPPING_* constants (which are not in
+	// this stack).
+	RID rd_native_fused_post_chain_shader;
+	RID rd_native_fused_post_chain_pipeline;
+	bool rd_native_fused_post_chain_load_failed = false;
+	bool rd_native_fused_post_chain_active_logged = false;
+	// GRX Route B rd_native fused_post_chain (patch 0045 in-place revision, Design
+	// 1 shadow-recompute): a self-owned 1x1 R32_SFLOAT STORAGE scratch texture
+	// bound to the fused kernel's dst_luminance UAV (u1). The public Luminance API
+	// (patch 0048 getters) now exposes DISTINCT current / previous / penultimate
+	// luminance buffers, so the fused gate binds real distinct SRV reads
