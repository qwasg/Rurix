diff --git a/drivers/d3d12/d3d12_hooks.h b/drivers/d3d12/d3d12_hooks.h
index dd40ad0..c794049 100644
--- a/drivers/d3d12/d3d12_hooks.h
+++ b/drivers/d3d12/d3d12_hooks.h
@@ -252,5 +252,33 @@ public:
 	// false so any hooks that do not override this (or the absence of a hooks
 	// singleton) keep the native Godot luminance_reduction + tonemap chain.
 	virtual bool try_record_fused_post_chain_rd_native(RID p_src_color, RID p_lum_source, RID p_prev_luminance, RID p_dst_color, RID p_dst_luminance, Size2i p_source_size, Size2i p_dest_size, float p_exposure, float p_white, float p_luminance_multiplier, float p_min_luminance, float p_max_luminance, float p_exposure_adjust, float p_first_frame, float p_auto_exposure_scale) { return false; }
+	// GRX-015 Route B rd_native gpu_culling (patch 0046, R1 revision): opt-in
+	// in-frame RD-native compute cull hook that drives a RURIX-OWNED scratch
+	// indirect-args buffer, NOT Godot's live MultiMesh command buffer. The first
+	// shipped 0046 wrote the reduced InstanceCount straight into the live
+	// multimesh->command_buffer via a same-frame compute UAV + buffer_clear; that
+	// buffer is simultaneously the DrawIndexedInstanced indirect-argument source for
+	// the native draw in the SAME frame, and the dual role is a GPU-side execution
+	// hazard the D3D12 draw-graph does not synchronize (device removal, 0x887A0005;
+	// not a CPU-side validation error — confirmed silent under both the debug layer
+	// and GPU-Based Validation). This R1 hook NEVER touches the live command buffer
+	// with compute/clear: p_commands (the live buffer) is ONLY a buffer_copy READ
+	// source; the module copies the p_command_bytes command template into the
+	// caller-owned p_scratch_commands buffer (a storage_buffer_create with
+	// DISPATCH_INDIRECT usage), buffer_clear's ONLY the SCRATCH buffer's count dwords
+	// + the visibility bitmask, binds t0=transforms / t1=frustum_planes /
+	// u0=SCRATCH_commands / u1=visibility, and dispatches ceil(instance_count/64).
+	// The caller then retargets the native indirect draw to read the scratch buffer.
+	// Returning true means the module recorded the in-frame cull into the scratch
+	// buffer (the caller reads scratch for this base); false is a fail-closed no-op
+	// (the native CPU-written command buffer keeps driving the draw). CAVEAT: R1 is a
+	// CANDIDATE — if the fault is a general RDG gap for "a draw-indirect buffer
+	// written by compute and consumed the same frame" rather than something specific
+	// to the live command buffer's out-of-graph state, a fully-Rurix-owned buffer
+	// hits the same wall; R1 ships only after the enablement smoke shows NO device
+	// removal on real hardware. The base implementation returns false so hooks that
+	// do not override this (or the absence of a hooks singleton) keep the native
+	// CPU-driven command buffer.
+	virtual bool try_record_gpu_culling_rd_native(RID p_transforms, RID p_commands, RID p_scratch_commands, RID p_visibility, const uint8_t *p_frustum_planes, uint32_t p_frustum_planes_bytes, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes, uint32_t p_instance_count, uint32_t p_surface_count, uint32_t p_command_stride_dwords, uint32_t p_instance_count_dword_index, uint32_t p_visibility_bytes, uint32_t p_command_bytes) { return false; }
 	static D3D12Hooks *get_singleton() { return singleton; }
 };
diff --git a/modules/rurix_accel/register_types.cpp b/modules/rurix_accel/register_types.cpp
index 23a0f0a..9096fee 100644
--- a/modules/rurix_accel/register_types.cpp
+++ b/modules/rurix_accel/register_types.cpp
@@ -394,6 +394,26 @@ void initialize_rurix_accel_module(ModuleInitializationLevel p_level) {
 	// hardcoded to a res:// resource so the smoke/bench harnesses can point at an
 	// absolute staging path.
 	GLOBAL_DEF_BASIC("rendering/rurix_accel/passes/fused_post_chain/rd_container_path", "");
+	// GRX-015 Route B rd_native gpu_culling: three-state backend selector for the
