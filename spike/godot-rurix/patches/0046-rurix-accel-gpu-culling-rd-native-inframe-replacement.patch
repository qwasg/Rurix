diff --git a/modules/rurix_accel/rurix_accel.cpp b/modules/rurix_accel/rurix_accel.cpp
index 7c14f3a..7139e49 100644
--- a/modules/rurix_accel/rurix_accel.cpp
+++ b/modules/rurix_accel/rurix_accel.cpp
@@ -1801,4 +1801,138 @@ bool RurixAccelD3D12Hooks::try_record_fused_post_chain_rd_native(RID p_src_color
 	return true;
 }
 
+bool RurixAccelD3D12Hooks::try_record_gpu_culling_rd_native(RID p_transforms, RID p_commands, RID p_visibility, const uint8_t *p_frustum_planes, uint32_t p_frustum_planes_bytes, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes, uint32_t p_instance_count, uint32_t p_surface_count, uint32_t p_command_stride_dwords, uint32_t p_instance_count_dword_index, uint32_t p_visibility_bytes) {
+	// GRX-015 Route B rd_native gpu_culling: an in-frame RD-native compute cull.
+	// This does NOT go through the Rurix rxgd bridge/shim; it drives the main
+	// RenderingDevice directly so the RD::buffer_clear -> compute dispatch -> native
+	// draw_list_draw_indirect chain is a first-class draw-graph citizen (the shim's
+	// side-channel dispatch was invisible to the graph, which then transitioned the
+	// command buffer to INDIRECT_ARGUMENT while a side-channel UAV write was still
+	// in flight — the device-removal hazard). Every early return keeps the native
+	// CPU-driven command buffer untouched (fail-closed no-op — an additive miss,
+	// never a fallback dispatch). The caller only reaches here when the gpu_culling
+	// backend selector is 2 (rd_native).
+	RenderingDevice *rd = RenderingDevice::get_singleton();
+	if (rd == nullptr) {
+		return false;
+	}
+	if (rd_native_gpu_culling_load_failed) {
+		// A prior container load / pipeline compile failed; do not retry every
+		// frame. The native CPU-driven command buffer keeps driving the draw.
+		return false;
+	}
+	if (!p_transforms.is_valid() || !p_commands.is_valid() || !p_visibility.is_valid()) {
+		return false;
+	}
+	if (p_instance_count == 0 || p_surface_count == 0 || p_command_stride_dwords == 0) {
+		return false;
+	}
+	if (p_frustum_planes == nullptr || p_frustum_planes_bytes != GPU_CULLING_RD_NATIVE_FRUSTUM_PLANES_BYTES) {
+		// The t1 planes payload must be the exact 96-byte / 6x float4 block.
+		return false;
+	}
+	if (p_push_constants == nullptr || p_push_constant_bytes != GPU_CULLING_RD_NATIVE_ROOT_CONSTANT_BYTES) {
+		// The b0 must be the exact 48-byte Rurix-defined block.
+		return false;
+	}
+	if (p_visibility_bytes == 0 || (p_visibility_bytes % 4u) != 0) {
+		// buffer_clear requires a dword-multiple size.
+		return false;
+	}
+	// Lazily build the compute pipeline the first time backend == 2 is exercised:
+	// read the Rurix container bytes, hand them to shader_create_from_bytecode
+	// (-> shader_create_from_container in the D3D12 driver), and create the compute
+	// pipeline. Any failure latches rd_native_gpu_culling_load_failed so it is not
+	// retried per frame.
+	if (!rd_native_gpu_culling_shader.is_valid() || !rd_native_gpu_culling_pipeline.is_valid()) {
+		const String container_path = GLOBAL_GET("rendering/rurix_accel/passes/gpu_culling/rd_container_path");
+		if (container_path.is_empty()) {
+			// No container configured: keep rd_native fail-closed (disabled).
+			rd_native_gpu_culling_load_failed = true;
+			return false;
+		}
+		const Vector<uint8_t> container_bytes = FileAccess::get_file_as_bytes(container_path);
+		if (container_bytes.is_empty()) {
+			rd_native_gpu_culling_load_failed = true;
+			print_verbose(vformat("RurixAccel: rd_native gpu_culling container '%s' missing or empty; native CPU-driven command buffer remains active.", container_path));
+			return false;
+		}
+		const RID shader = rd->shader_create_from_bytecode(container_bytes);
+		if (!shader.is_valid()) {
+			rd_native_gpu_culling_load_failed = true;
+			print_verbose("RurixAccel: rd_native gpu_culling shader_create_from_bytecode failed; native CPU-driven command buffer remains active.");
+			return false;
+		}
+		const RID pipeline = rd->compute_pipeline_create(shader);
+		if (!pipeline.is_valid()) {
+			rd->free_rid(shader);
+			rd_native_gpu_culling_load_failed = true;
+			print_verbose("RurixAccel: rd_native gpu_culling compute_pipeline_create failed; native CPU-driven command buffer remains active.");
+			return false;
+		}
+		rd_native_gpu_culling_shader = shader;
+		rd_native_gpu_culling_pipeline = pipeline;
+		if (!rd_native_gpu_culling_active_logged) {
+			// One-shot marker (NOT per-frame): the RD-native cull is engaged.
+			print_verbose("RXGD_RD_NATIVE_GPU_CULLING active: backend=rd_native, in-frame compute cull engaged (main RenderingDevice buffer_clear -> dispatch -> indirect-draw; native CPU count overwritten in-frame).");
+			rd_native_gpu_culling_active_logged = true;
+		}
+	}
+	// Lazily create the self-owned 96-byte frustum-planes SSBO (the t1
+	// StructuredBuffer<float4>) and buffer_update it with THIS frame's 6 planes.
+	// buffer_update happens BEFORE compute_list_begin (updating buffers is forbidden
+	// while a compute list is active); the draw graph tracks the update and barriers
+	// it against the compute read.
+	if (!rd_native_gpu_culling_frustum_planes_buffer.is_valid()) {
+		rd_native_gpu_culling_frustum_planes_buffer = rd->storage_buffer_create(GPU_CULLING_RD_NATIVE_FRUSTUM_PLANES_BYTES);
+		if (!rd_native_gpu_culling_frustum_planes_buffer.is_valid()) {
+			// Planes buffer allocation failed: keep the native path (fail-closed).
+			return false;
+		}
+	}
+	rd->buffer_update(rd_native_gpu_culling_frustum_planes_buffer, 0, GPU_CULLING_RD_NATIVE_FRUSTUM_PLANES_BYTES, p_frustum_planes);
+	// Pre-dispatch zeroing on the MAIN RenderingDevice, BEFORE compute_list_begin
+	// (buffer_clear is hard-forbidden while a compute list is active). Zero ONLY
+	// each surface's instance-count dword (byte offset (s*command_stride_dwords +
+	// instance_count_dword_index)*4; mirrors the CPU write at mesh_storage.cpp:2210)
+	// and the whole visibility bitmask, so the kernel's InterlockedAdd/InterlockedOr
+	// accumulate from 0; every other command dword (dword 0 = vertices-drawn count)
+	// is preserved. The draw graph tracks these clears and barriers them against the
+	// compute dispatch and the later indirect draw.
+	for (uint32_t s = 0; s < p_surface_count; s++) {
+		rd->buffer_clear(p_commands, (s * p_command_stride_dwords + p_instance_count_dword_index) * (uint32_t)sizeof(uint32_t), (uint32_t)sizeof(uint32_t));
+	}
+	rd->buffer_clear(p_visibility, 0, p_visibility_bytes);
+	// Bind the four structured buffers in the container's binding order: t0 =
+	// src_transforms, t1 = frustum_planes (SRV), u0 = dst_commands, u1 =
+	// dst_visibility (UAV), all as UNIFORM_TYPE_STORAGE_BUFFER (RAW/structured
+	// runtime equivalence — the buffer probe precedent). UniformSetCacheRD keys on
+	// the RID set; the module-owned planes buffer RID is stable so the cached set
+	// stays valid while its CONTENTS are refreshed each frame via buffer_update.
+	const RID uniform_set = UniformSetCacheRD::get_singleton()->get_cache(
+			rd_native_gpu_culling_shader, 0,
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_STORAGE_BUFFER, 0, p_transforms),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_STORAGE_BUFFER, 1, rd_native_gpu_culling_frustum_planes_buffer),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_STORAGE_BUFFER, 2, p_commands),
+			RenderingDevice::Uniform(RenderingDevice::UNIFORM_TYPE_STORAGE_BUFFER, 3, p_visibility));
+	if (!uniform_set.is_valid()) {
+		return false;
+	}
+	// 48-byte b0 root constants built by the call site (instance/stride/surface/
+	// command params + local bounding sphere), passed through verbatim.
+	uint8_t push_constants[GPU_CULLING_RD_NATIVE_ROOT_CONSTANT_BYTES] = {};
+	memcpy(push_constants, p_push_constants, GPU_CULLING_RD_NATIVE_ROOT_CONSTANT_BYTES);
+	// Record the in-frame cull: one thread per instance, [numthreads(64,1,1)],
+	// dispatch ceil(instance_count/64). No submit()/sync() (a local-RD-only
+	// concept); the main-RD draw graph inserts the required barriers automatically.
+	const RenderingDevice::ComputeListID compute_list = rd->compute_list_begin();
+	rd->compute_list_bind_compute_pipeline(compute_list, rd_native_gpu_culling_pipeline);
+	rd->compute_list_bind_uniform_set(compute_list, uniform_set, 0);
+	rd->compute_list_set_push_constant(compute_list, push_constants, GPU_CULLING_RD_NATIVE_ROOT_CONSTANT_BYTES);
+	const uint32_t groups_x = (p_instance_count + 63u) / 64u;
+	rd->compute_list_dispatch(compute_list, groups_x, 1, 1);
+	rd->compute_list_end();
+	return true;
+}
+
 #endif // D3D12_ENABLED
diff --git a/modules/rurix_accel/rurix_accel.h b/modules/rurix_accel/rurix_accel.h
index e15f56e..60be139 100644
--- a/modules/rurix_accel/rurix_accel.h
+++ b/modules/rurix_accel/rurix_accel.h
@@ -256,6 +256,23 @@ class RurixAccelD3D12Hooks : public D3D12Hooks {
 	// FUSED_POST_CHAIN_RESOURCE_MAPPING_* constants so the two tails never collide.
 	static constexpr uint32_t RD_NATIVE_FUSED_POST_CHAIN_ROOT_CONSTANT_BYTES = 64;
 	static constexpr uint32_t RD_NATIVE_FUSED_POST_CHAIN_RESOURCE_COUNT = 5;
+	// GRX-015 Route B rd_native gpu_culling (patch 0046): lazily-built RD compute
+	// pipeline for the in-frame cull, plus a self-owned frustum-planes SSBO (the t1
+	// StructuredBuffer<float4>, buffer_update'd per frame). Same lifetime discipline
+	// as the members above; rd_native_gpu_culling_load_failed latches a load/compile
+	// failure so it is not retried every frame, and rd_native_gpu_culling_active_logged
+	// gates the one-shot RXGD_RD_NATIVE_GPU_CULLING active marker (not per-frame).
+	// The 48-byte b0 / 4-resource contract (src_transforms SRV t0, frustum_planes SRV
+	// t1, dst_commands UAV u0, dst_visibility UAV u1) matches
+	// gpu_culling_rd_native_descriptor_layout.json.
+	RID rd_native_gpu_culling_shader;
+	RID rd_native_gpu_culling_pipeline;
+	RID rd_native_gpu_culling_frustum_planes_buffer;
+	bool rd_native_gpu_culling_load_failed = false;
+	bool rd_native_gpu_culling_active_logged = false;
+	static constexpr uint32_t GPU_CULLING_RD_NATIVE_ROOT_CONSTANT_BYTES = 48;
+	static constexpr uint32_t GPU_CULLING_RD_NATIVE_FRUSTUM_PLANES_BYTES = 96;
+	static constexpr uint32_t GPU_CULLING_RD_NATIVE_RESOURCE_COUNT = 4;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_ROOT_CONSTANT_BYTES = 28;
 	static constexpr uint32_t LUMINANCE_RESOURCE_MAPPING_RESOURCE_COUNT = 2;
 	// GRX-010 tonemap resource mapping (resource_mapping.md): b0 carries
@@ -495,6 +512,20 @@ public:
 	// failure returns false and the caller keeps the tonemap rd_native / native chain
 	// (fail-closed).
 	bool try_record_fused_post_chain_rd_native(RID p_src_color, RID p_lum_source, RID p_prev_luminance, RID p_dst_color, RID p_dst_luminance, Size2i p_source_size, Size2i p_dest_size, float p_exposure, float p_white, float p_luminance_multiplier) override;
+	// GRX-015 Route B rd_native gpu_culling: in-frame RD-native compute cull (patch
+	// 0046; additive). Lazily builds the RD compute pipeline from the Rurix container
+	// named by rendering/rurix_accel/passes/gpu_culling/rd_container_path, lazily
+	// creates + per-frame buffer_update's the self-owned 96-byte frustum-planes SSBO
+	// (t1), RD::buffer_clear's each surface's instance-count dword and the whole
+	// visibility bitmask BEFORE opening its own compute list, binds src_transforms
+	// (SRV t0), frustum_planes (SRV t1), dst_commands (UAV u0) and dst_visibility
+	// (UAV u1), and dispatches ceil(instance_count/64) on the main RenderingDevice.
+	// Returns true only when the cull was actually recorded; any fail-closed step
+	// (RD unavailable, latched load failure, invalid RID, missing/invalid container,
+	// pipeline/uniform-set failure, planes-buffer allocation failure, or a
+	// malformed b0/planes payload) returns false and the caller keeps the native
+	// CPU-driven command buffer (a no-op additive miss, never a fallback dispatch).
+	bool try_record_gpu_culling_rd_native(RID p_transforms, RID p_commands, RID p_visibility, const uint8_t *p_frustum_planes, uint32_t p_frustum_planes_bytes, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes, uint32_t p_instance_count, uint32_t p_surface_count, uint32_t p_command_stride_dwords, uint32_t p_instance_count_dword_index, uint32_t p_visibility_bytes) override;
 };
 
 #endif // D3D12_ENABLED
diff --git a/servers/rendering/renderer_rd/forward_clustered/render_forward_clustered.cpp b/servers/rendering/renderer_rd/forward_clustered/render_forward_clustered.cpp
index 4235e40..a47ac55 100644
--- a/servers/rendering/renderer_rd/forward_clustered/render_forward_clustered.cpp
+++ b/servers/rendering/renderer_rd/forward_clustered/render_forward_clustered.cpp
@@ -2087,6 +2087,123 @@ void RenderForwardClustered::_render_scene(RenderDataRD *p_render_data, const Co
 			}
 		}
 	}
+	// GRX-015 Route B rd_native gpu_culling call-site (patch 0046). Independent of
+	// the shim path above (gated on .../gpu_culling/enabled, driving the out-of-frame
+	// rxgd bridge): this path is gated on the .../gpu_culling/backend == 2 selector
+	// and drives the MAIN RenderingDevice directly, so the RD::buffer_clear ->
+	// compute dispatch -> native draw_list_draw_indirect chain is fully visible to
+	// the draw graph's ResourceTracker (which inserts the barriers). This
+	// structurally avoids the shim path's device-removal hazard: the shim's
+	// side-channel dispatch was invisible to the draw graph, so after the count-dword
+	// clear the graph transitioned the command buffer to INDIRECT_ARGUMENT while the
+	// side-channel UAV write was still in flight. The default backend == 0 pays
+	// nothing here; a failed record is a no-op (the CPU-written count survives, an
+	// additive miss, never a fallback dispatch). This is the FIRST rd_native pass
+	// that itself issues buffer_clear (all clears happen in the module BEFORE its
+	// compute_list_begin, since buffer_clear is forbidden while a compute list is
+	// active).
