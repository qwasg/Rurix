diff --git a/drivers/d3d12/d3d12_hooks.h b/drivers/d3d12/d3d12_hooks.h
index 0bddfe0..7efc1b4 100644
--- a/drivers/d3d12/d3d12_hooks.h
+++ b/drivers/d3d12/d3d12_hooks.h
@@ -252,5 +252,25 @@ public:
 	// false so any hooks that do not override this (or the absence of a hooks
 	// singleton) keep the native Godot luminance_reduction + tonemap chain.
 	virtual bool try_record_fused_post_chain_rd_native(RID p_src_color, RID p_lum_source, RID p_prev_luminance, RID p_dst_color, RID p_dst_luminance, Size2i p_source_size, Size2i p_dest_size, float p_exposure, float p_white, float p_luminance_multiplier) { return false; }
+	// GRX-015 Route B rd_native gpu_culling: opt-in in-frame RD-native compute cull
+	// hook (patch 0046; additive — no native Godot compute pass is replaced). Unlike
+	// the shim-path try_record_gpu_culling() above (which takes native
+	// ID3D12Resource* handles for an out-of-frame bridge dispatch), this hook takes
+	// Godot RID handles for the three structured buffers in the container's binding
+	// order — src_transforms (SRV t0), dst_commands (UAV u0) and dst_visibility
+	// (UAV u1) — plus the 96-byte frustum-planes payload (the t1
+	// StructuredBuffer<float4>, buffer_update'd by the module), the 48-byte b0 root
+	// constants, and the instance/surface/stride parameters needed to zero the count
+	// dwords + bitmask and size the dispatch. The module buffer_update's the planes,
+	// RD::buffer_clear's each surface's count dword and the whole bitmask BEFORE
+	// opening its own compute_list (buffer_clear is forbidden while a compute list is
+	// active), binds the four structured buffers, and dispatches
+	// ceil(instance_count/64) on the main RenderingDevice so the clear -> dispatch ->
+	// native indirect-draw chain is a first-class draw-graph citizen (barriers auto).
+	// Returning true means the module recorded the in-frame cull; false means it did
+	// nothing (fail-closed no-op — the CPU-written command-buffer count survives).
+	// The base implementation returns false so hooks that do not override this (or
+	// the absence of a hooks singleton) keep the native CPU-driven command buffer.
+	virtual bool try_record_gpu_culling_rd_native(RID p_transforms, RID p_commands, RID p_visibility, const uint8_t *p_frustum_planes, uint32_t p_frustum_planes_bytes, const uint8_t *p_push_constants, uint32_t p_push_constant_bytes, uint32_t p_instance_count, uint32_t p_surface_count, uint32_t p_command_stride_dwords, uint32_t p_instance_count_dword_index, uint32_t p_visibility_bytes) { return false; }
 	static D3D12Hooks *get_singleton() { return singleton; }
 };
