extends Node

const TARGET_BACKEND := "__TARGET_BACKEND__"
const DEFAULT_WARMUP_FRAMES := __DEFAULT_WARMUP_FRAMES__
const DEFAULT_SAMPLE_FRAMES := __DEFAULT_SAMPLE_FRAMES__
const DEFAULT_VSYNC_ENABLED := __DEFAULT_VSYNC_ENABLED__
const DEFAULT_RESOLUTION := Vector2i(
    __DEFAULT_RESOLUTION_WIDTH__,
    __DEFAULT_RESOLUTION_HEIGHT__
)
const DEFAULT_EVIDENCE_LEVEL := "measured_local"
const DEFAULT_RUN_MODE := "full"
const DEFAULT_LEG := "baseline"
const DEFAULT_GPU_TIMESTAMPS := false
# Reserved bucket key for the synthetic whole-frame GPU duration (first-to-last
# captured marker delta). The "__" prefix can never collide with a real Godot
# RENDER_TIMESTAMP marker name.
const GPU_FRAME_TOTAL_BUCKET := "__frame_total__"
# A single captured GPU bucket delta above this (microseconds) is treated as
# garbage and discarded. A real per-pass or whole-frame GPU cost is at most a few
# milliseconds even on a heavily loaded frame, so 5 s is an unreachable sanity
# ceiling that only trips on a zero/overflowed timestamp_frequency mapping.
const GPU_SAMPLE_MAX_US := 5000000.0

@onready var scene_container: Node = $SceneContainer

var scene_name := ""
var scene_path := ""
var raw_output_path := ""
var warmup_frames := DEFAULT_WARMUP_FRAMES
var sample_frames := DEFAULT_SAMPLE_FRAMES
var vsync_enabled := DEFAULT_VSYNC_ENABLED
var resolution := DEFAULT_RESOLUTION
var evidence_level := DEFAULT_EVIDENCE_LEVEL
var run_mode := DEFAULT_RUN_MODE
var leg := DEFAULT_LEG
var pass_matrix_path := ""
var pass_matrix := {}
var gpu_timestamps_enabled := DEFAULT_GPU_TIMESTAMPS

var loaded_scene: Node = null
var frame_times_ms: Array[float] = []
var processed_frames := 0
var sampling_complete := false

# GPU timestamp capture state (only used when --gpu-timestamps is passed, which
# is also what makes the Python runner add Godot's --gpu-profile so the
# RenderingDevice actually captures timestamps). The RD getters assert
# ERR_RENDER_THREAD_GUARD, so they must be called from the render thread; with
# the default rendering/driver/threads/thread_model (RENDER_THREAD_SAFE, which
# the generated project.godot leaves unset) the render thread IS the main thread
# that runs _process, so the direct calls below are valid. A separate render
# thread would require RenderingServer.call_on_render_thread() instead.
var _rd: RenderingDevice = null
var _gpu_bucket_samples := {}
var _gpu_frames_sampled := 0
var _gpu_discarded_samples := 0
var _gpu_last_captured_frame := -1
var _gpu_frame_queue_size := 0


func _ready() -> void:
    var config := _parse_runner_config()
    scene_name = str(config.get("scene_name", ""))
    scene_path = str(config.get("scene_path", ""))
    raw_output_path = str(config.get("raw_output_path", ""))
    warmup_frames = int(config.get("warmup_frames", DEFAULT_WARMUP_FRAMES))
    sample_frames = int(config.get("sample_frames", DEFAULT_SAMPLE_FRAMES))
    vsync_enabled = bool(config.get("vsync", DEFAULT_VSYNC_ENABLED))
    resolution = config.get("resolution", DEFAULT_RESOLUTION)
    evidence_level = str(config.get("evidence_level", DEFAULT_EVIDENCE_LEVEL))
    run_mode = str(config.get("run_mode", DEFAULT_RUN_MODE))
    leg = str(config.get("leg", DEFAULT_LEG))
    pass_matrix_path = str(config.get("pass_matrix_path", ""))
    pass_matrix = _load_pass_matrix(pass_matrix_path)
    gpu_timestamps_enabled = bool(config.get("gpu_timestamps", DEFAULT_GPU_TIMESTAMPS))

    if scene_name.is_empty() or scene_path.is_empty() or raw_output_path.is_empty():
        _fail_and_quit("missing required runner arguments")
        return
    if warmup_frames <= 0 or sample_frames <= 0:
        _fail_and_quit("warmup_frames and sample_frames must be positive")
        return

    _apply_display_configuration()
    if not _load_target_scene():
        return

    if gpu_timestamps_enabled:
        _init_gpu_timestamp_capture()

    print("[benchmark-runner] scene_name=%s" % scene_name)
    print("[benchmark-runner] scene_path=%s" % scene_path)
    print("[benchmark-runner] raw_output_path=%s" % raw_output_path)
    set_process(true)


func _process(delta: float) -> void:
    if sampling_complete:
        return

    processed_frames += 1
    if processed_frames <= warmup_frames:
        return

    var frame_time_ms := delta * 1000.0
    if frame_time_ms <= 0.0:
        _fail_and_quit("encountered non-positive frame time")
        return

    frame_times_ms.append(frame_time_ms)
    # Sample GPU timestamps in the SAME post-warmup window as the frame times
    # (captured results lag by frame_queue_size frames; that inherent ~2-frame
    # offset at the window edges is accepted rather than corrected).
    if gpu_timestamps_enabled:
        _collect_gpu_timestamps()
    if frame_times_ms.size() >= sample_frames:
        sampling_complete = true
        _write_success_payload()
        get_tree().quit(0)


func _parse_runner_config() -> Dictionary:
    var args := OS.get_cmdline_user_args()
    var config := {
        "warmup_frames": DEFAULT_WARMUP_FRAMES,
        "sample_frames": DEFAULT_SAMPLE_FRAMES,
        "vsync": DEFAULT_VSYNC_ENABLED,
        "resolution": DEFAULT_RESOLUTION,
        "evidence_level": DEFAULT_EVIDENCE_LEVEL,
        "run_mode": DEFAULT_RUN_MODE,
        "leg": DEFAULT_LEG,
        "pass_matrix_path": "",
        "gpu_timestamps": DEFAULT_GPU_TIMESTAMPS,
    }

    var index := 0
    while index < args.size():
        var key := args[index]
        if not key.begins_with("--"):
            index += 1
            continue
        if index + 1 >= args.size():
            break
        var value := args[index + 1]
        match key:
            "--scene-name":
                config["scene_name"] = value
            "--scene-path":
                config["scene_path"] = value
            "--raw-output-path":
                config["raw_output_path"] = value
            "--warmup-frames":
                config["warmup_frames"] = int(value)
            "--sample-frames":
                config["sample_frames"] = int(value)
            "--vsync":
                config["vsync"] = _parse_bool(value)
            "--resolution-width":
                var width := int(value)
                var current_resolution: Vector2i = config["resolution"]
                config["resolution"] = Vector2i(width, current_resolution.y)
            "--resolution-height":
                var height := int(value)
                var current_resolution: Vector2i = config["resolution"]
                config["resolution"] = Vector2i(current_resolution.x, height)
            "--evidence-level":
                config["evidence_level"] = value
            "--run-mode":
                config["run_mode"] = value
            "--leg":
                config["leg"] = value
            "--pass-matrix-path":
                config["pass_matrix_path"] = value
            "--gpu-timestamps":
                config["gpu_timestamps"] = _parse_bool(value)
        index += 2
    return config


func _load_pass_matrix(path: String) -> Dictionary:
    # Echo the rurix-leg pass matrix into the raw payload. The Python runner
    # writes the same matrix into override.cfg; here we only record it.
    if path.is_empty():
        return {}
    if not FileAccess.file_exists(path):
        return {}
    var file := FileAccess.open(path, FileAccess.READ)
    if file == null:
        return {}
    var text := file.get_as_text()
    file.close()
    var parsed: Variant = JSON.parse_string(text)
    if typeof(parsed) != TYPE_DICTIONARY:
        return {}
    if parsed.has("settings") and typeof(parsed["settings"]) == TYPE_DICTIONARY:
        return parsed["settings"]
    return parsed


func _parse_bool(value: String) -> bool:
    var normalized := value.strip_edges().to_lower()
    return normalized in ["1", "true", "yes", "on"]


func _apply_display_configuration() -> void:
    var window := get_window()
    if window != null:
        window.size = resolution
    if vsync_enabled:
        DisplayServer.window_set_vsync_mode(DisplayServer.VSYNC_ENABLED)
    else:
        DisplayServer.window_set_vsync_mode(DisplayServer.VSYNC_DISABLED)


func _load_target_scene() -> bool:
    var packed_scene := load(scene_path)
    if packed_scene == null:
        _fail_and_quit("failed to load scene: %s" % scene_path)
        return false

    loaded_scene = packed_scene.instantiate()
    if loaded_scene == null:
        _fail_and_quit("failed to instantiate scene: %s" % scene_path)
        return false

    scene_container.add_child(loaded_scene)
    return true


func _write_success_payload() -> void:
    var avg_frame_time_ms := _mean(frame_times_ms)
    # Empty {} when no GPU timestamps were captured (e.g. --gpu-timestamps not
    # passed, or a headless/dummy RenderingDevice). Never emit fabricated values:
    # gpu_timestamps_available reflects real data and the gpu_timestamps key is
    # omitted entirely when absent.
    var gpu_ts: Dictionary = _gpu_timestamps_payload()
    var payload := {
        "status": "success",
        "scene_name": scene_name,
        "scene_path": scene_path,
        "warmup_frames": warmup_frames,
        "sample_frames": sample_frames,
        "frame_times_ms": frame_times_ms,
        "avg_fps": 1000.0 / avg_frame_time_ms,
        "p95_frame_time_ms": _compute_p95(frame_times_ms),
        "gpu_timestamps_available": not gpu_ts.is_empty(),
        "gpu_frame_times_ms": null,
        "evidence_level": evidence_level,
        "run_mode": run_mode,
        "leg": leg,
        "pass_matrix": pass_matrix,
        "resolution": [resolution.x, resolution.y],
        "vsync": vsync_enabled,
        "target_backend": TARGET_BACKEND,
        "sample_count": frame_times_ms.size(),
    }
    if not gpu_ts.is_empty():
        payload["gpu_timestamps"] = gpu_ts
    _write_payload(payload)
    print(
        "[benchmark-runner] completed scene=%s samples=%d avg_fps=%.3f p95_ms=%.3f"
        % [scene_name, frame_times_ms.size(), payload["avg_fps"], payload["p95_frame_time_ms"]]
    )


func _fail_and_quit(error_message: String) -> void:
    var payload := {
        "status": "error",
        "error": error_message,
        "scene_name": scene_name,
        "scene_path": scene_path,
        "warmup_frames": warmup_frames,
        "sample_frames": sample_frames,
        "frame_times_ms": frame_times_ms,
        "avg_fps": null,
        "p95_frame_time_ms": null,
        "gpu_timestamps_available": false,
        "gpu_frame_times_ms": null,
        "evidence_level": evidence_level,
        "run_mode": run_mode,
        "leg": leg,
        "pass_matrix": pass_matrix,
        "resolution": [resolution.x, resolution.y],
        "vsync": vsync_enabled,
        "target_backend": TARGET_BACKEND,
        "sample_count": frame_times_ms.size(),
    }
    _write_payload(payload)
    push_error(error_message)
    print("[benchmark-runner] ERROR %s" % error_message)
    get_tree().quit(1)


func _write_payload(payload: Dictionary) -> void:
    var directory_path := raw_output_path.get_base_dir()
    var mkdir_error := DirAccess.make_dir_recursive_absolute(directory_path)
    if mkdir_error != OK:
        push_error("failed to create output directory: %s" % directory_path)
        return
    var file := FileAccess.open(raw_output_path, FileAccess.WRITE)
    if file == null:
        push_error("failed to open output file: %s" % raw_output_path)
        return
    file.store_string(JSON.stringify(payload, "  ") + "\n")
    file.close()


func _mean(values: Array[float]) -> float:
    var total := 0.0
    for value in values:
        total += value
    return total / float(values.size())


func _compute_p95(values: Array[float]) -> float:
    var sorted_values := values.duplicate()
    sorted_values.sort()
    var index := int(ceil(float(sorted_values.size()) * 0.95)) - 1
    index = min(max(index, 0), sorted_values.size() - 1)
    return sorted_values[index]


func _median(values: Array[float]) -> float:
    var sorted_values := values.duplicate()
    sorted_values.sort()
    var n := sorted_values.size()
    if n == 0:
        return 0.0
    if n % 2 == 1:
        return sorted_values[n / 2]
    return (sorted_values[n / 2 - 1] + sorted_values[n / 2]) * 0.5


func _gpu_sample_valid(dur_us: float) -> bool:
    # Guard against a zero/overflowed device timestamp_frequency producing an
    # inf/nan or negative/absurd delta (a documented failure mode of the driver
    # tick-to-time mapping); such a sample is dropped and counted, never stored.
    return is_finite(dur_us) and dur_us >= 0.0 and dur_us < GPU_SAMPLE_MAX_US


func _init_gpu_timestamp_capture() -> void:
    _rd = RenderingServer.get_rendering_device()
    if _rd == null:
        push_warning(
            "gpu timestamps requested but RenderingServer.get_rendering_device() "
            + "returned null; no gpu_timestamps will be recorded"
        )
        return
    # Informational only: captured results lag by frame_queue_size frames.
    var fq: Variant = ProjectSettings.get_setting(
        "rendering/rendering_device/vsync/frame_queue_size", 2
    )
    _gpu_frame_queue_size = int(fq) if fq != null else 0
    print(
        "[benchmark-runner] gpu_timestamps capture armed (frame_queue_size=%d)"
        % _gpu_frame_queue_size
    )


func _collect_gpu_timestamps() -> void:
    if _rd == null:
        return
    var frame_index := int(_rd.get_captured_timestamps_frame())
    # Captured results lag by frame_queue_size frames and the same batch can be
    # observed by more than one _process tick; dedup on the captured frame index
    # so each rendered frame contributes at most one sample per bucket.
    if frame_index == _gpu_last_captured_frame:
        return
    var count := int(_rd.get_captured_timestamps_count())
    if count < 2:
        # Need at least two markers to form a single [i, i+1] delta.
        _gpu_last_captured_frame = frame_index
        return
    var names := []
    var gpu_times := []
    names.resize(count)
    gpu_times.resize(count)
    for i in range(count):
        names[i] = _rd.get_captured_timestamp_name(i)
        gpu_times[i] = _rd.get_captured_timestamp_gpu_time(i)
    # Per-frame per-name aggregation mirroring RenderingServerDefault's own GPU
    # profiler: the bucket duration of marker i is gpu_time[i+1]-gpu_time[i]
    # (nanoseconds; /1000.0 -> microseconds), markers sharing a name within a
    # frame are summed into that frame's single sample, and scope markers whose
    # name begins with "<" or ">" are skipped exactly as the engine does.
    var frame_bucket := {}
    for i in range(count - 1):
        var marker_name: String = names[i]
        if marker_name.is_empty() or marker_name.begins_with("<") or marker_name.begins_with(">"):
            continue
        var dur_us := float(gpu_times[i + 1] - gpu_times[i]) / 1000.0
        if not _gpu_sample_valid(dur_us):
            _gpu_discarded_samples += 1
            continue
        frame_bucket[marker_name] = float(frame_bucket.get(marker_name, 0.0)) + dur_us
    # Whole-frame GPU total = first-to-last captured marker delta.
    var total_us := float(gpu_times[count - 1] - gpu_times[0]) / 1000.0
    if _gpu_sample_valid(total_us):
        frame_bucket[GPU_FRAME_TOTAL_BUCKET] = total_us
    else:
        _gpu_discarded_samples += 1
    for bucket_name in frame_bucket:
        if not _gpu_bucket_samples.has(bucket_name):
            _gpu_bucket_samples[bucket_name] = []
        _gpu_bucket_samples[bucket_name].append(frame_bucket[bucket_name])
    _gpu_frames_sampled += 1
    _gpu_last_captured_frame = frame_index


func _gpu_timestamps_payload() -> Dictionary:
    if _gpu_frames_sampled <= 0 or _gpu_bucket_samples.is_empty():
        return {}
    var buckets := {}
    for bucket_name in _gpu_bucket_samples:
        var raw_samples: Array = _gpu_bucket_samples[bucket_name]
        if raw_samples.is_empty():
            continue
        var typed: Array[float] = []
        for value in raw_samples:
            typed.append(float(value))
        buckets[bucket_name] = {
            "count": typed.size(),
            "mean_us": _mean(typed),
            "median_us": _median(typed),
            "p95_us": _compute_p95(typed),
        }
    if buckets.is_empty():
        return {}
    return {
        "unit": "microseconds",
        "frames_sampled": _gpu_frames_sampled,
        "discarded_samples": _gpu_discarded_samples,
        "frame_queue_size": _gpu_frame_queue_size,
        "buckets": buckets,
    }
