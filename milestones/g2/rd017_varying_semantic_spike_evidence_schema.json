{
  "title": "RD-017 varying 语义名保名机制 spike 证据(选项① HLSL 边界改写)",
  "description": "G2.4 RD-017 取证 spike(measured-first / blocked-honest):输出 varying / fragment 输入 varying 用户语义名经 HLSL 边界改写后,dxc 接受 + signature_gate 不放宽也过 + 物理 ABI 不变 + 确定性。纯取证非性能基准,不入 budget counter;golden bless / device 真跑 / RD-017 状态翻转归 agent(G-G2-4)。",
  "type": "object",
  "required": ["schema_version", "subject", "rd_ref", "status", "samples", "summary", "timestamp"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": 1 },
    "subject": { "const": "rd017_varying_semantic_rewrite" },
    "rd_ref": { "const": "RD-017" },
    "decision_ref": { "type": "string" },
    "status": { "enum": ["measured_local", "blocked"] },
    "host_env": { "type": "object" },
    "tool_versions": { "type": "object" },
    "validator_note": { "type": "string" },
    "notes": { "type": "string" },
    "timestamp": { "type": "string" },
    "samples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string" },
          "profile": { "type": "string" },
          "checked_part": { "type": "string" },
          "status": { "enum": ["measured_local", "blocked"] },
          "hlsl_abi_neutral": { "type": "object" },
          "binary_abi_diff": { "type": "object" },
          "gate_before_rewrite": { "type": "object" },
          "gate_after_rewrite": { "type": "object" },
          "determinism": { "type": "object" }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["samples_measured"],
      "additionalProperties": true,
      "properties": {
        "samples_measured": { "type": "integer" },
        "all_dxc_accept_after_rewrite": { "type": "boolean" },
        "all_gate_pass_after_rewrite_unrelaxed": { "type": "boolean" },
        "all_gate_reject_before_rewrite": { "type": "boolean" },
        "all_hlsl_abi_neutral": { "type": "boolean" },
        "all_physical_abi_invariant": { "type": "boolean" },
        "all_deterministic": { "type": "boolean" }
      }
    }
  }
}
