{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UC-05 RHI I1~I10 不变量矩阵证据 schema(EI1.3,RXS-0264;G-EI1-3 / G-EI1-5)",
  "description": "evidence/uc05_invariant_matrix.json 的结构硬门。RXS-0264 redline F3:schema 层禁止 I9 / I10 出现无 in-repo 出处的数值字段——本 schema 令 invariant 条目字段全部为 string 或 null(additionalProperties:false),**任何 number 类型值即 schema 违例**,由此 by-construction 封死杜撰 Python 数字窗口(I9/I10 Python 侧 = 无数字定性历史陈述)。裁决 1 三档:compile_time(编译期 typeck / --emit=check 即拦)/ assembly_time(submit 图装配期 host 确定性拦)/ lib_tested(库单测已证,.rx 接线随 EI1.4)/ report_only(运行期观测,documented_historical)。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject",
    "milestone",
    "historical_counters",
    "tiers",
    "invariants"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "subject": { "type": "string", "const": "uc05_invariant_matrix" },
    "milestone": { "type": "string" },
    "historical_counters": {
      "type": "string",
      "description": "RXS-0264 顶部醒目标注:对照口径显式声明历史计数器不在仓库、不可复跑、零杜撰数字。",
      "pattern": "unavailable in-repo"
    },
    "date": { "type": "string" },
    "tiers": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "invariants": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "tier", "clause", "evidence_level"],
        "properties": {
          "id": { "type": "string", "pattern": "^I([1-9]|10)$" },
          "name": { "type": "string" },
          "tier": {
            "type": "string",
            "enum": ["compile_time", "assembly_time", "lib_tested", "report_only"]
          },
          "mechanism": { "type": "string" },
          "clause": { "type": "string", "pattern": "^RXS-\\d{4}$" },
          "diagnostic": { "type": ["string", "null"] },
          "corpus": { "type": "string" },
          "lib_test": { "type": "string" },
          "rx_wiring": { "type": "string" },
          "evidence_level": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
