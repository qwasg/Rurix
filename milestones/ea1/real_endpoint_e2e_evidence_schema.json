{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rurix://schemas/evidence/ea1_real_endpoint_e2e/v1",
  "title": "Rurix EA1.2 真端点闭环 e2e 证据 JSON(G-EA1-3/G-EA1-4;RXS-0216~0218)",
  "description": "真实 GitHub Releases 端点的完整用户路径实测(bootstrap 下载 rurixup.exe → 锚 → 四级内容寻址校验 → 物化 → 探针),measured_local,不进 CI 硬门(G-EA1-3:真端点闭环归 EA1.2 e2e evidence,不进 pr-smoke)。与冷启动两段(install_e2e_evidence_schema.json,裁决 C)互斥不混用:本档允许开发机热环境,不冒充 vm_rxcheck/gpu_first_kernel 段。",
  "type": "object",
  "required": [
    "kind",
    "date",
    "host",
    "toolchain_version",
    "anchor_channel",
    "release_run",
    "steps",
    "t_start",
    "t_end",
    "digest_levels_verified",
    "components",
    "attempt",
    "pass"
  ],
  "properties": {
    "kind": { "type": "string", "const": "ea1.2_real_endpoint_e2e" },
    "description": { "type": "string" },
    "date": { "type": "string" },
    "host": {
      "type": "object",
      "required": ["os", "cpu", "gpu", "driver"],
      "properties": {
        "os": { "type": "string" },
        "cpu": { "type": "string" },
        "gpu": { "type": "string" },
        "driver": { "type": "string" }
      }
    },
    "toolchain_version": { "type": "string" },
    "anchor_channel": { "type": "string", "description": "锚获取通道与其合入留痕(owner 人工门 PR)。" },
    "release_run": { "type": "string", "description": "产出资产的 release run URL 与触发方式留痕。" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "cmd", "exit", "duration_s"],
        "properties": {
          "name": { "type": "string" },
          "cmd": { "type": "string" },
          "exit": { "type": "integer" },
          "duration_s": { "type": "number", "minimum": 0 },
          "note": { "type": "string" }
        }
      }
    },
    "t_start": { "type": "string", "format": "date-time" },
    "t_end": { "type": "string", "format": "date-time" },
    "duration_s_install_chain": { "type": "number", "minimum": 0 },
    "digest_levels_verified": { "type": "integer", "const": 4 },
    "components": { "type": "array", "minItems": 3, "items": { "type": "string" } },
    "rt_cabi_gap_closed": { "type": "string" },
    "bytes_downloaded_note": { "type": "string" },
    "bandwidth_note": { "type": "string" },
    "attempt": { "type": "integer", "minimum": 1 },
    "pass": { "type": "boolean" },
    "pending": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
