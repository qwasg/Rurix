//
// M5.4 G-M5-4 GREEN fixture: fixed version of race_shared.ptx (bar.sync added).
//
// Same logic as race_shared.ptx but inserts bar.sync 0; between writing sdata[tid]
// and reading sdata[tid ^ 1], removing the cross-thread shared-memory race.
// compute-sanitizer --tool racecheck MUST turn green (0 hazards). The two states
// together form the G-M5-4 real red/green verification trail.
//
// ASCII only: ptxas rejects non-ASCII bytes.
//
.version 8.0
.target sm_52
.address_size 64

.visible .entry clean_shared(
    .param .u64 clean_shared_param_0
)
{
    .reg .b32   %r<4>;
    .reg .b64   %rd<8>;

    .shared .align 4 .b32 sdata[64];

    ld.param.u64    %rd1, [clean_shared_param_0];
    cvta.to.global.u64  %rd2, %rd1;

    mov.u32     %r1, %tid.x;
    mul.wide.u32    %rd3, %r1, 4;

    // sdata[tid] = tid
    mov.u64     %rd4, sdata;
    add.s64     %rd5, %rd4, %rd3;
    st.shared.u32   [%rd5], %r1;

    // <<< fix: barrier so all writes complete before any read >>>
    bar.sync    0;

    // r3 = sdata[tid ^ 1]
    xor.b32     %r2, %r1, 1;
    mul.wide.u32    %rd6, %r2, 4;
    add.s64     %rd7, %rd4, %rd6;
    ld.shared.u32   %r3, [%rd7];

    // out[tid] = r3
    add.s64     %rd2, %rd2, %rd3;
    st.global.u32   [%rd2], %r3;
    ret;
}
